#!/usr/bin/env bash
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MAE_CERT_SOURCE_ONLY=1 source "$root/scripts/certify-live-swarm"

tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/mae-cert-test.XXXXXX")"
trap 'rm -rf "$tmpdir"' EXIT

pass_count=0

write_case() {
  local name="$1"
  local body="$2"
  printf '%s\n' "$body" > "$tmpdir/$name.txt"
}

expect_success() {
  local label="$1"
  shift
  if "$@"; then
    pass_count=$((pass_count + 1))
  else
    echo "FAIL expected success: $label" >&2
    exit 1
  fi
}

expect_failure() {
  local label="$1"
  shift
  if ( "$@" ) >/dev/null 2>&1; then
    echo "FAIL expected failure: $label" >&2
    exit 1
  else
    pass_count=$((pass_count + 1))
  fi
}

write_case clean "VERDICT: PASS
No P0/P1 blockers found."
expect_failure "clean no blocker language is not a blocker" has_actual_blocker "$tmpdir/clean.txt"

write_case blocker_severity_first "P1 finding: command injection in server.ts"
expect_success "severity-first blocker detected" has_actual_blocker "$tmpdir/blocker_severity_first.txt"

write_case blocker_signal_first "Finding: P0 unsafe exec command injection"
expect_success "signal-first blocker detected" has_actual_blocker "$tmpdir/blocker_signal_first.txt"

write_case seeded "P1 finding: command injection via exec(\"nslookup \" + name)"
expect_success "seeded evidence accepts normal lowercase n text" has_seeded_command_injection_evidence "$tmpdir/seeded.txt"

write_case seeded_inverse "command injection through child_process exec is P0"
expect_success "seeded evidence accepts evidence before severity" has_seeded_command_injection_evidence "$tmpdir/seeded_inverse.txt"

write_case prompt_echo "Prompt says find command injection, but no severity assigned."
expect_failure "prompt echo without severity rejected" has_seeded_command_injection_evidence "$tmpdir/prompt_echo.txt"

write_case negated_ready "This is not certification ready because it lacks the required readiness marker."
expect_failure "negated readiness rejected" marks_certification_ready "$tmpdir/negated_ready.txt"

write_case false_ready "Certification ready: false
certification_ready: false"
expect_failure "false readiness rejected" marks_certification_ready "$tmpdir/false_ready.txt"

write_case true_ready "Certification ready: true"
expect_success "true readiness accepted" marks_certification_ready "$tmpdir/true_ready.txt"

write_case prompt_echo_ready "The fixture lacks CERTIFICATION_READY marker."
expect_failure "prompt echo readiness marker rejected" marks_certification_ready "$tmpdir/prompt_echo_ready.txt"

write_case explicit_marker "CERTIFICATION_READY"
expect_success "exact explicit marker is ready" marks_certification_ready "$tmpdir/explicit_marker.txt"

trace_dir="$tmpdir/traces"
session_id="00000000-0000-0000-0000-000000000001"
mkdir -p "$trace_dir/$session_id/artifacts"
printf 'synthesis output\n' > "$trace_dir/$session_id/artifacts/synth-00000000-output-abc.txt"
printf '%s\n' \
  '{"type":"agent.end","session_id":"00000000-0000-0000-0000-000000000001","agent_id":"worker","output_artifact":"00000000-0000-0000-0000-000000000001/artifacts/worker-output-abc.txt"}' \
  '{"type":"agent.end","session_id":"00000000-0000-0000-0000-000000000001","agent_id":"synth-00000000","output_artifact":"00000000-0000-0000-0000-000000000001/artifacts/synth-00000000-output-abc.txt"}' \
  > "$trace_dir/$session_id.jsonl"
artifact="$(review_report_path "$session_id" "$tmpdir/fallback.txt")"
[[ "$artifact" == "$trace_dir/$session_id/artifacts/synth-00000000-output-abc.txt" ]] || {
  echo "FAIL expected synthesis artifact, got $artifact" >&2
  exit 1
}
pass_count=$((pass_count + 1))

nograde_session="00000000-0000-0000-0000-000000000002"
mkdir -p "$trace_dir/$nograde_session/artifacts"
printf 'CERTIFICATION_CONTRACT:\nschema_version: 1\nverdict: pass\np0_count: 0\np1_count: 0\nperspectives_covered: correctness, adversarial, quality, security, domain\nblockers: none\nfailed_teams: none\ncertification_ready: true\nEND_CERTIFICATION_CONTRACT\n' > "$trace_dir/$nograde_session/artifacts/pi-orchestrator-output-final.txt"
printf '%s\n' \
  '{"type":"agent.end","session_id":"00000000-0000-0000-0000-000000000002","agent_id":"pi-orchestrator","output_artifact":"00000000-0000-0000-0000-000000000002/artifacts/pi-orchestrator-output-draft.txt"}' \
  '{"type":"agent.end","session_id":"00000000-0000-0000-0000-000000000002","agent_id":"pi-orchestrator","output_artifact":"00000000-0000-0000-0000-000000000002/artifacts/pi-orchestrator-output-final.txt"}' \
  > "$trace_dir/$nograde_session.jsonl"
nograde_artifact="$(review_report_path "$nograde_session" "$tmpdir/fallback.txt")"
[[ "$nograde_artifact" == "$trace_dir/$nograde_session/artifacts/pi-orchestrator-output-final.txt" ]] || {
  echo "FAIL expected no-grade pi orchestrator artifact, got $nograde_artifact" >&2
  exit 1
}
pass_count=$((pass_count + 1))

write_case contract_clean "CERTIFICATION_CONTRACT:
schema_version: 1
session_id: test
artifact_ref: test
verdict: pass
p0_count: 0
p1_count: 0
perspectives_covered: correctness, adversarial, quality, security, domain
blockers: none
failed_teams: none
certification_ready: true
END_CERTIFICATION_CONTRACT"
expect_success "clean contract validates" validate_certification_contract "$tmpdir/contract_clean.txt" clean

