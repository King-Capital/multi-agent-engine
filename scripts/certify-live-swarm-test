schema_version: 1
session_id: test
artifact_ref: test
verdict: pass
p0_count: 0
p1_count: 0
perspectives_covered: correctness, adversarial, quality, security, domain
blockers: P1 unsafe command injection
failed_teams: none
certification_ready: true
END_CERTIFICATION_CONTRACT"
expect_failure "clean contract with blockers rejected" validate_certification_contract "$tmpdir/contract_clean_blockers.txt" clean

write_case contract_clean_legacy "VERDICT:       PASS
P0_BLOCKERS:   0
P1_BLOCKERS:   0
PERSPECTIVES:  correctness=CLEAN adversarial=CLEAN quality=CLEAN security=CLEAN domain=CLEAN
CERTIFICATION:  The clean fixture contains no P0/P1 blockers and passes all five canonical review perspectives."
expect_failure "legacy clean contract rejected" validate_certification_contract "$tmpdir/contract_clean_legacy.txt" clean

write_case contract_placeholder "CERTIFICATION_CONTRACT:
schema_version: 1
verdict: pass|fail
p0_count: <integer>
p1_count: <integer>
perspectives_covered: correctness, adversarial, quality, security, domain
blockers: none
failed_teams: none
certification_ready: true|false
END_CERTIFICATION_CONTRACT"
expect_failure "placeholder contract rejected" validate_certification_contract "$tmpdir/contract_placeholder.txt" clean

write_case failing_contradictory "CERTIFICATION_CONTRACT:
schema_version: 1
session_id: test
artifact_ref: test
verdict: pass
p0_count: 0
p1_count: 0
perspectives_covered: correctness, adversarial, quality, security, domain
blockers: none
failed_teams: none
certification_ready: false
END_CERTIFICATION_CONTRACT"
expect_failure "failing contract requires fail verdict" validate_certification_contract "$tmpdir/failing_contradictory.txt" failing

printf '%s\n' '{"event_type":"worker_failed","session_id":"00000000-0000-0000-0000-000000000001"}' >> "$trace_dir/$session_id.jsonl"
expect_success "operational failure detected" trace_has_operational_failures "$trace_dir/$session_id.jsonl"

write_case contract_missing_ready "CERTIFICATION_CONTRACT:
schema_version: 1
verdict: pass
p0_count: 0
p1_count: 0
perspectives_covered: correctness, adversarial, quality, security, domain
blockers: none
failed_teams: none
END_CERTIFICATION_CONTRACT"
expect_failure "contract missing certification_ready rejected" validate_certification_contract "$tmpdir/contract_missing_ready.txt" clean

write_case contract_failed_team_ready "CERTIFICATION_CONTRACT:
schema_version: 1
verdict: pass
p0_count: 0
p1_count: 0
perspectives_covered: correctness, adversarial, quality, security, domain
blockers: none
failed_teams: Security Review
certification_ready: true
END_CERTIFICATION_CONTRACT"
expect_failure "contract with failed team rejected" validate_certification_contract "$tmpdir/contract_failed_team_ready.txt" clean

make_health_trace() {
  local id="$1"
  local lead_count="${2:-5}"
  local extra="${3:-}"
  local leads=("pi-correctness-lead" "pi-adversarial-lead" "pi-quality-lead" "pi-security-lead" "pi-domain-lead")
  local teams=("Correctness Review" "Adversarial Review" "Quality Review" "Security Review" "Domain Review")
  mkdir -p "$trace_dir/$id/artifacts"
  {
    printf '%s\n' '{"type":"session.start","session_id":"'"$id"'"}'
    local i=0
    while [[ "$i" -lt "$lead_count" && "$i" -lt "${#leads[@]}" ]]; do
      printf '%s\n' '{"type":"agent.end","session_id":"'"$id"'","agent_id":"'"${leads[$i]}"'","team":"'"${teams[$i]}"'"}'
      i=$((i + 1))
    done
    if [[ -n "$extra" ]]; then
      printf '%s\n' "$extra"
    fi
    printf '%s\n' '{"type":"session.end","session_id":"'"$id"'","status":"completed"}'
  } > "$trace_dir/$id.jsonl"
}

