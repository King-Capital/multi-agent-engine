#!/usr/bin/env bash
set -euo pipefail

# mae -- Multi-Agent Engine CLI
# Install: curl -fsSL https://raw.githubusercontent.com/King-Capital/multi-agent-engine/main/scripts/mae | bash -s install
# Or:      mae install

MAE_VERSION="1.0.21"
MAE_REPO="King-Capital/multi-agent-engine"
MAE_GIT_URL="${MAE_GIT_URL:-https://github.com/${MAE_REPO}.git}"
MAE_REF="${MAE_REF:-main}"
MAE_UPDATE_REF="${MAE_UPDATE_REF:-main}"
MAE_REQUIRE_PI="${MAE_REQUIRE_PI:-1}"
MAE_INSTALL_DIR="${MAE_HOME:-$HOME/.mae}"
MAE_CONFIG="$MAE_INSTALL_DIR/config"
MAE_BIN="${MAE_BIN:-${HOME}/.local/bin/mae}"

# ── Load config (created during install, user-editable) ─────────────
if [[ -f "$MAE_CONFIG" ]]; then
  # shellcheck source=/dev/null
  source "$MAE_CONFIG"
fi

MAE_REPO_DIR="${MAE_REPO_DIR:-$MAE_INSTALL_DIR/repo}"

# Apply defaults for anything not set by config or env
MAE_DASHBOARD_URL="${MAE_DASHBOARD_URL:-http://localhost:8400}"
DATABASE_URL="${DATABASE_URL:-postgres://mae:mae@localhost:5432/mae?sslmode=disable}"
MAE_API_URL="${MAE_API_URL:-http://localhost:8400}"
MAE_TRACE_DIR="${MAE_TRACE_DIR:-$MAE_INSTALL_DIR/traces}"
MAE_LLM_GATEWAY_URL="${MAE_LLM_GATEWAY_URL:-}"
MAE_LLM_GATEWAY_KEY="${MAE_LLM_GATEWAY_KEY:-}"
MAE_API_TOKEN="${MAE_API_TOKEN:-}"
MAE_DEFAULT_ADAPTER="${MAE_DEFAULT_ADAPTER:-}"
MAE_A2A_URL="${MAE_A2A_URL:-}"
MAE_A2A_TOKEN="${MAE_A2A_TOKEN:-}"
MAE_A2A_DEFAULT_HOST="${MAE_A2A_DEFAULT_HOST:-}"
MAE_A2A_DEFAULT_PORT="${MAE_A2A_DEFAULT_PORT:-41271}"
LANGFUSE_PUBLIC_KEY="${LANGFUSE_PUBLIC_KEY:-}"
LANGFUSE_SECRET_KEY="${LANGFUSE_SECRET_KEY:-}"
LANGFUSE_HOST="${LANGFUSE_HOST:-}"
LITELLM_API_BASE="${LITELLM_API_BASE:-${MAE_LLM_GATEWAY_URL:-}}"
LITELLM_API_KEY="${LITELLM_API_KEY:-${MAE_LLM_GATEWAY_KEY:-}}"
ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-${MAE_LLM_GATEWAY_URL:-}}"
ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-${MAE_LLM_GATEWAY_KEY:-${LITELLM_API_KEY:-}}}"
export MAE_DASHBOARD_URL DATABASE_URL MAE_API_URL MAE_TRACE_DIR MAE_LLM_GATEWAY_URL MAE_LLM_GATEWAY_KEY
export MAE_API_TOKEN MAE_DEFAULT_ADAPTER MAE_A2A_URL MAE_A2A_TOKEN MAE_A2A_DEFAULT_HOST MAE_A2A_DEFAULT_PORT
export LANGFUSE_PUBLIC_KEY LANGFUSE_SECRET_KEY LANGFUSE_HOST
export LITELLM_API_BASE LITELLM_API_KEY ANTHROPIC_BASE_URL ANTHROPIC_API_KEY

write_shell_var() {
  local key="$1"
  local value="$2"
  printf '%s=' "$key"
  printf '%q' "$value"
  printf '\n'
}

write_optional_shell_var() {
  local key="$1"
  local value="$2"
  if [[ -n "$value" ]]; then
    write_shell_var "$key" "$value"
  else
    printf '# %s=""\n' "$key"
  fi
}

upsert_config_var() {
  local key="$1"
  local value="$2"
  local line tmp
  line="$(write_shell_var "$key" "$value")"
  mkdir -p "$(dirname "$MAE_CONFIG")"
  touch "$MAE_CONFIG"
  tmp="$(mktemp "${MAE_CONFIG}.XXXXXX")"
  awk -v key="$key" -v line="$line" '
    BEGIN { done = 0 }
    $0 ~ "^[[:space:]]*#?[[:space:]]*" key "=" {
      if (!done) {
        print line
        done = 1
      }
      next
    }
    { print }
    END {
      if (!done) print line
    }
  ' "$MAE_CONFIG" > "$tmp"
  mv "$tmp" "$MAE_CONFIG"
}

display_version() {
  local root
  root="$(find_mae_root 2>/dev/null || true)"
  if [[ -n "$root" ]] && [[ -f "$root/VERSION" ]]; then
    tr -d '[:space:]' < "$root/VERSION"
  else
    echo "$MAE_VERSION"
  fi
}

sync_install_version() {
  local root="$1"
  local version="unknown"
  if [[ -f "$root/VERSION" ]]; then
    version="$(tr -d '[:space:]' < "$root/VERSION")"
  else
    version="$MAE_VERSION"
  fi
  mkdir -p "$MAE_INSTALL_DIR"
  printf '%s\n' "$version" > "$MAE_INSTALL_DIR/VERSION"
}

# ── Locate MAE root ──────────────────────────────────────────────────
find_mae_root() {
  # 1. MAE_ROOT env var
  if [[ -n "${MAE_ROOT:-}" ]] && [[ -f "$MAE_ROOT/engine/cli.ts" ]]; then
    echo "$MAE_ROOT"; return
  fi
  # 2. Current repo-backed install location
  if [[ -f "$MAE_REPO_DIR/engine/cli.ts" ]]; then
    echo "$MAE_REPO_DIR"; return
  fi
  # 3. Legacy install location
  if [[ -f "$MAE_INSTALL_DIR/engine/cli.ts" ]]; then
    echo "$MAE_INSTALL_DIR"; return
  fi
  # 4. Walk up from script location (dev checkout)
  local dir="$(cd "$(dirname "$0")" && pwd)"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/engine/cli.ts" ]] && [[ -f "$dir/VERSION" ]]; then
      echo "$dir"; return
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

# ── Check dependencies ───────────────────────────────────────────────
check_deps() {
  local missing=()
  command -v bun >/dev/null 2>&1 || missing+=("bun")
  command -v git >/dev/null 2>&1 || missing+=("git")
  if [[ "$MAE_REQUIRE_PI" != "0" ]] && [[ "$MAE_REQUIRE_PI" != "false" ]]; then
    command -v pi >/dev/null 2>&1 || missing+=("pi")
  fi
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Missing dependencies: ${missing[*]}"
    if [[ " ${missing[*]} " == *" bun "* ]]; then
      echo "Install bun: curl -fsSL https://bun.sh/install | bash"
    fi
    if [[ " ${missing[*]} " == *" pi "* ]]; then
      echo "Install Pi before running real swarms, or set MAE_REQUIRE_PI=0 for echo/A2A-only installs."
    fi
    exit 1
  fi
}

# ── Install ──────────────────────────────────────────────────────────
do_install() {
  local dry_run=false
  if [[ "${1:-}" == "--dry-run" ]]; then
    dry_run=true
    echo "DRY RUN -- showing what would happen (no changes made)"
    echo ""
  fi

  check_deps

  echo "Install home: $MAE_INSTALL_DIR"
  echo "Repo target:  $MAE_REPO_DIR"
  echo ""

  if [[ -d "$MAE_REPO_DIR/.git" ]]; then
    echo "MAE already installed at $MAE_REPO_DIR"
    echo "Run 'mae update' to pull latest."
    exit 0
  fi

  if [[ -d "$MAE_INSTALL_DIR/.git" ]]; then
    echo "Legacy MAE install detected at $MAE_INSTALL_DIR"
    echo "Run 'MAE_REPO_DIR=$MAE_INSTALL_DIR mae update' to update it, or move it before installing the repo-backed layout."
    exit 1
  fi

  # Step 1: Clone
  echo "[1/4] Clone $MAE_REPO@$MAE_REF → $MAE_REPO_DIR"
  if ! $dry_run; then
    mkdir -p "$MAE_INSTALL_DIR"
    git clone --branch "$MAE_REF" "$MAE_GIT_URL" "$MAE_REPO_DIR" 2>&1
  fi

  # Step 2: Engine deps
  echo "[2/4] Install engine dependencies (bun install)"
  if ! $dry_run; then
    cd "$MAE_REPO_DIR/engine" && bun install
  fi

  # Step 3: Config
  if [[ -f "$MAE_CONFIG" ]] && ! $dry_run; then
    echo "[3/4] Config exists at $MAE_CONFIG (keeping current)"
  else
    echo "[3/4] Create config: $MAE_CONFIG"
    echo "      MAE_DASHBOARD_URL = $MAE_DASHBOARD_URL"
    echo "      DATABASE_URL      = $DATABASE_URL"
    echo "      MAE_API_URL       = $MAE_API_URL"
    echo "      MAE_LLM_GATEWAY_URL = $MAE_LLM_GATEWAY_URL"
    if ! $dry_run; then
      {
        cat << CONF
# MAE Configuration -- edit these values for your environment
# Sourced by the mae CLI on every invocation

# Dashboard / Go API server
CONF
        write_shell_var MAE_DASHBOARD_URL "$MAE_DASHBOARD_URL"
        cat << CONF

# PostgreSQL connection (used by Go dashboard)
CONF
        write_shell_var DATABASE_URL "$DATABASE_URL"
        cat << CONF

# API URL for dashboard-next Vite proxy
CONF
        write_shell_var MAE_API_URL "$MAE_API_URL"
        cat << CONF

# Trace storage
CONF
        write_shell_var MAE_TRACE_DIR "$MAE_TRACE_DIR"
        cat << CONF

# Repo checkout used by the wrapper CLI
CONF
        write_shell_var MAE_ROOT "$MAE_REPO_DIR"
        cat << CONF

# Optional LiteLLM/OpenAI-compatible gateway
CONF
        write_shell_var MAE_LLM_GATEWAY_URL "$MAE_LLM_GATEWAY_URL"
        write_optional_shell_var MAE_LLM_GATEWAY_KEY "$MAE_LLM_GATEWAY_KEY"
        cat << CONF

# Default adapter (pi, a2a, echo)
CONF
        write_optional_shell_var MAE_DEFAULT_ADAPTER "$MAE_DEFAULT_ADAPTER"
        cat << CONF

# API auth token (set if dashboard requires auth)
CONF
        write_optional_shell_var MAE_API_TOKEN "$MAE_API_TOKEN"
        cat << CONF

# Default A2A endpoint (for remote agent delegation)
CONF
        write_optional_shell_var MAE_A2A_DEFAULT_HOST "$MAE_A2A_DEFAULT_HOST"
        write_shell_var MAE_A2A_DEFAULT_PORT "$MAE_A2A_DEFAULT_PORT"
        write_optional_shell_var MAE_A2A_URL "$MAE_A2A_URL"
        write_optional_shell_var MAE_A2A_TOKEN "$MAE_A2A_TOKEN"
        cat << CONF

# Langfuse observability
CONF
        write_optional_shell_var LANGFUSE_PUBLIC_KEY "$LANGFUSE_PUBLIC_KEY"
        write_optional_shell_var LANGFUSE_SECRET_KEY "$LANGFUSE_SECRET_KEY"
        write_optional_shell_var LANGFUSE_HOST "$LANGFUSE_HOST"
        cat << CONF
CONF
      } > "$MAE_CONFIG"
    fi
  fi

  # Step 4: CLI binary
  echo "[4/4] Install CLI: $MAE_BIN"
  if ! $dry_run; then
    sync_install_version "$MAE_REPO_DIR"
    mkdir -p "$(dirname "$MAE_BIN")"
    cp "$MAE_REPO_DIR/scripts/mae" "$MAE_BIN"
    chmod +x "$MAE_BIN"
  fi

  echo ""
  if $dry_run; then
    echo "DRY RUN complete. Run 'mae install' to execute."
  else
    echo "✓ MAE installed (engine only -- no frontend)"
    echo "  Home:      $MAE_INSTALL_DIR"
    echo "  Root:      $MAE_REPO_DIR"
    echo "  Config:    $MAE_CONFIG"
    echo "  CLI:       $MAE_BIN"
    echo "  Dashboard: $MAE_DASHBOARD_URL"
    echo "  Database:  $DATABASE_URL"
    echo ""
    echo "Edit $MAE_CONFIG to customize. Then try: mae info"
    echo "To install the dashboard frontend: mae dashboard install"
  fi
}

# ── Dashboard management (opt-in) ──────────────────────────────────
do_dashboard() {
  local root
  root="$(find_mae_root)" || { echo "MAE not found. Run 'mae install' first."; exit 1; }

  local subcmd="${1:-help}"
  case "$subcmd" in
    install)
      echo "Installing dashboard-next frontend..."
      cd "$root/dashboard-next" && bun install
      echo "✓ Frontend deps installed."
      echo "  Start dev server: mae dashboard dev"
      echo "  Build for prod:   mae dashboard build"
      ;;
    dev)
      echo "Starting dashboard-next dev server (proxying to $MAE_API_URL)..."
      cd "$root/dashboard-next" && MAE_API_URL="$MAE_API_URL" bun run dev
      ;;
    build)
      echo "Building dashboard-next for production..."
      cd "$root/dashboard-next" && bun run build
      echo "✓ Built to dashboard-next/dist/"
      ;;
    *)
      local installed="no"
      [[ -d "$root/dashboard-next/node_modules" ]] && installed="yes"
      echo "MAE Dashboard Frontend"
      echo "  Installed: $installed"
      echo "  API:       $MAE_API_URL"
      echo "  Database:  $DATABASE_URL"
      echo ""
      echo "Commands:"
      echo "  mae dashboard install   Install frontend dependencies"
      echo "  mae dashboard dev       Start Vite dev server (port 5173)"
      echo "  mae dashboard build     Build for production to dist/"
      ;;
  esac
}

# ── Setup helpers ────────────────────────────────────────────────────
do_setup() {
  local root
  root="$(find_mae_root)" || { echo "MAE not found. Run 'mae install' first."; exit 1; }

  local subcmd="${1:-help}"
  shift || true
  case "$subcmd" in
    a2a)
      local url="${MAE_A2A_URL:-}"
      local token="${MAE_A2A_TOKEN:-}"
      local host="${MAE_A2A_DEFAULT_HOST:-}"
      local port="${MAE_A2A_DEFAULT_PORT:-41271}"
      local set_default=false
      local test_endpoint=true
      local use_standard=false

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --standard)
            use_standard=true
            shift
            ;;
          --host)
            host="${2:-}"
            use_standard=true
            shift 2
            ;;
          --host=*)
            host="${1#--host=}"
            use_standard=true
            shift
            ;;
          --port)
            port="${2:-}"
            use_standard=true
            shift 2
            ;;
          --port=*)
            port="${1#--port=}"
            use_standard=true
            shift
            ;;
          --url)
            url="${2:-}"
            shift 2
            ;;
          --url=*)
            url="${1#--url=}"
            shift
            ;;
          --token)
            token="${2:-}"
            shift 2
            ;;
          --token=*)
            token="${1#--token=}"
            shift
            ;;
          --default-adapter)
            set_default=true
            shift
            ;;
          --no-test)
            test_endpoint=false
            shift
            ;;
          --test)
            test_endpoint=true
            shift
            ;;
          -h|--help)
            cat <<'HELP'
mae setup a2a [--standard] [--host <host>] [--port <port>] [--url <endpoint>] [--token <token>] [--default-adapter] [--no-test]

Writes A2A configuration into ~/.mae/config and verifies discovery by default.
The standard endpoint is built from MAE_A2A_DEFAULT_HOST and MAE_A2A_DEFAULT_PORT.
Set them in ~/.mae/config using the names shown in .env.example, or pass --host/--port.

Examples:
  mae setup a2a --standard
  mae setup a2a --host "$MAE_A2A_DEFAULT_HOST" --port "$MAE_A2A_DEFAULT_PORT"
  mae setup a2a --url "$MAE_A2A_URL"
  mae setup a2a --url "$MAE_A2A_URL" --default-adapter
  mae setup a2a --url http://agent-host:41271 --token "$A2A_TOKEN"
HELP
            exit 0
            ;;
          *)
            echo "Unknown setup a2a option: $1"
            echo "Run: mae setup a2a --help"
            exit 1
            ;;
        esac
      done

      if [[ -z "$url" && ( "$use_standard" == true || ! -t 0 ) ]]; then
        if [[ -z "$host" ]]; then
          echo "MAE_A2A_DEFAULT_HOST is required for --standard."
          echo "Set MAE_A2A_DEFAULT_HOST in ~/.mae/config (see .env.example) or pass --host."
          exit 1
        fi
        url="http://${host}:${port}"
      fi
      if [[ -z "$url" && -t 0 ]]; then
        if [[ -n "$host" ]]; then
          echo "Press Enter to use standard endpoint http://${host}:${port}"
        else
          echo "No standard A2A host configured. Set MAE_A2A_DEFAULT_HOST in ~/.mae/config or enter a full endpoint URL."
        fi
        read -r -p "A2A endpoint URL: " url
        if [[ -z "$url" && -n "$host" ]]; then
          url="http://${host}:${port}"
        fi
      fi
      if [[ -z "$url" ]]; then
        echo "A2A endpoint URL required."
        echo "Run: mae setup a2a --standard"
        exit 1
      fi

      upsert_config_var MAE_A2A_DEFAULT_HOST "$host"
      upsert_config_var MAE_A2A_DEFAULT_PORT "$port"
      upsert_config_var MAE_A2A_URL "$url"
      if [[ -n "$token" ]]; then
        upsert_config_var MAE_A2A_TOKEN "$token"
      fi
      if $set_default; then
        upsert_config_var MAE_DEFAULT_ADAPTER "a2a"
      fi

      echo "✓ A2A config updated: $MAE_CONFIG"
      echo "  MAE_A2A_URL=$url"
      if $set_default; then
        echo "  MAE_DEFAULT_ADAPTER=a2a"
      fi

      if $test_endpoint; then
        echo ""
        echo "Testing A2A discovery..."
        if [[ -n "$token" ]]; then
          MAE_A2A_URL="$url" MAE_A2A_TOKEN="$token" bun "$root/engine/cli.ts" discover "$url" --a2a-token "$token"
        else
          MAE_A2A_URL="$url" bun "$root/engine/cli.ts" discover "$url"
        fi
      fi
      ;;
    qmd)
      local collection="mae"
      local embed=false
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --name)
            collection="${2:-}"
            shift 2
            ;;
          --name=*)
            collection="${1#--name=}"
            shift
            ;;
          --embed)
            embed=true
            shift
            ;;
          -h|--help)
            cat <<'HELP'
mae setup qmd [--name <collection>] [--embed]

Registers the installed MAE repo as a qmd collection for fast repo search.
Default collection name: mae

Examples:
  mae setup qmd
  mae setup qmd --embed
  mae setup qmd --name multi-agent-engine --embed
HELP
            exit 0
            ;;
          *)
            echo "Unknown setup qmd option: $1"
            echo "Run: mae setup qmd --help"
            exit 1
            ;;
        esac
      done

      if [[ -z "$collection" ]]; then
        echo "qmd collection name required."
        exit 1
      fi
      if ! command -v qmd >/dev/null 2>&1; then
        echo "qmd not found. Install qmd before running mae setup qmd."
        exit 1
      fi

      echo "Registering qmd collection '$collection' for $root..."
      if qmd ls "$collection" >/dev/null 2>&1; then
        qmd update
      else
        qmd collection add "$root" --name "$collection" --mask '**/*.{ts,tsx,js,jsx,md,yaml,yml,json,toml,sh}'
      fi
      if $embed; then
        qmd embed
      else
        echo "Skipping embeddings. Run 'mae setup qmd --embed' to enable semantic search."
      fi
      ;;
    help|--help|-h|"")
      cat <<'HELP'
mae setup — Configure optional MAE integrations

Commands:
  mae setup a2a --standard         Configure/test standard MAE A2A delegation
  mae setup a2a --url <endpoint>   Configure/test custom remote A2A delegation
  mae setup qmd [--embed]          Register this repo as a qmd collection

Examples:
  mae setup a2a --standard
  mae setup a2a --host "$MAE_A2A_DEFAULT_HOST" --port "$MAE_A2A_DEFAULT_PORT"
  mae setup a2a --url "$MAE_A2A_URL"
  mae setup a2a --url "$MAE_A2A_URL" --default-adapter
  mae setup qmd --embed
HELP
      ;;
    *)
      echo "Unknown setup command: $subcmd"
      echo "Run: mae setup --help"
      exit 1
      ;;
  esac
}

# ── Update ───────────────────────────────────────────────────────────
do_update() {
  check_deps

  local root
  root="$(find_mae_root)" || { echo "MAE not found. Run 'mae install' first."; exit 1; }

  echo "Updating MAE at $root..."

  cd "$root"
  local before=$(git rev-parse HEAD)
  local branch
  branch="$(git symbolic-ref --short -q HEAD || true)"
  if [[ -z "$branch" ]]; then
    echo "Detached install detected; switching to origin/$MAE_UPDATE_REF before update."
    git fetch origin "$MAE_UPDATE_REF" --tags
    git checkout -B "$MAE_UPDATE_REF" "origin/$MAE_UPDATE_REF"
  else
    git pull --ff-only 2>&1
  fi
  local after=$(git rev-parse HEAD)

  if [[ "$before" == "$after" ]]; then
    echo "Already up to date."
  else
    echo "Updated: $(git log --oneline ${before}..${after} | wc -l | tr -d ' ') new commits"
    git log --oneline "${before}..${after}"
  fi

  # Reinstall engine deps in case they changed
  echo "Updating engine dependencies..."
  cd "$root/engine" && bun install
  sync_install_version "$root"

  # Update the CLI script itself
  if [[ -f "$MAE_BIN" ]]; then
    local target_bin="$MAE_BIN"
    local symlink_depth=0
    while [[ -L "$target_bin" ]]; do
      symlink_depth=$((symlink_depth + 1))
      if [[ "$symlink_depth" -gt 10 ]]; then
        echo "Too many symlinks while resolving $MAE_BIN"
        exit 1
      fi
      local link_target
      link_target="$(readlink "$target_bin")"
      if [[ "$link_target" == /* ]]; then
        target_bin="$link_target"
      else
        target_bin="$(cd "$(dirname "$target_bin")" && pwd)/$link_target"
      fi
    done

    local tmp_bin
    tmp_bin="$(mktemp "$(dirname "$target_bin")/.mae.XXXXXX")"
    cleanup_tmp_bin() {
      [[ -n "${tmp_bin:-}" && -e "$tmp_bin" ]] && rm -f "$tmp_bin"
    }
    trap cleanup_tmp_bin RETURN
    install -m 0755 "$root/scripts/mae" "$tmp_bin"
    mv -f "$tmp_bin" "$target_bin"
    tmp_bin=""
    trap - RETURN
    echo "CLI updated."
  fi

  echo ""
  echo "✓ MAE updated"
  local ver=$(cat "$root/VERSION" 2>/dev/null || echo "unknown")
  echo "  Version: $ver"
}

# ── Uninstall ────────────────────────────────────────────────────────
do_uninstall() {
  echo "Uninstalling MAE..."
  if [[ -f "$MAE_BIN" ]]; then
    rm "$MAE_BIN"
    echo "Removed $MAE_BIN"
  fi
  if [[ -d "$MAE_INSTALL_DIR" ]]; then
    read -p "Remove $MAE_INSTALL_DIR, including repo/config/traces? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      rm -rf "$MAE_INSTALL_DIR"
      echo "Removed $MAE_INSTALL_DIR"
    fi
  fi
  echo "✓ MAE uninstalled"
}

# ── Help ─────────────────────────────────────────────────────────────
do_help() {
  local version
  version="$(display_version)"
  cat <<HELP
mae -- Multi-Agent Engine CLI v${version}

Lifecycle:
  mae install              Clone repo, install engine deps, create config
  mae install --dry-run    Preview install steps without making changes
  mae setup a2a            Configure/test optional A2A delegation
  mae setup qmd            Register repo with qmd for indexed code search
  mae update               Pull latest, reinstall deps, update CLI
  mae uninstall            Remove CLI and optionally the repo

Dashboard (opt-in):
  mae dashboard            Show dashboard status
  mae dashboard install    Install frontend deps (dashboard-next)
  mae dashboard dev        Start Vite dev server (port 5173)
  mae dashboard build      Build frontend for production

Run swarms:
  mae task <description>   Run plan-build-review on a task (default chain)
  mae chain <name> <task>  Run a specific chain
  mae run <prompt> [args]  Run a reusable prompt workflow

Chains:
  plan-build-review        Plan → build → validate (default)
  full-stack-specialized   Frontend + Backend + Systems + QA + Security leads
  backend-only             Backend + QA + Security
  frontend-only            Frontend + QA
  review-only              Red + Blue team code review
  build-verify             Builder-verifier loop with escalation

Sessions:
  mae session list         List all sessions
  mae session close <id>   Close a session (--status done|error)

Info:
  mae info                 System overview (chains, adapters, routing, health)
  mae version              Version and connection info
  mae adapters             List available adapters
  mae discover <url>       Discover a remote A2A agent
  mae config               Show current config
  mae config edit          Open config in \$EDITOR

Agents:
  mae new-agent <name> <role> <team>   Scaffold a new agent persona

Options:
  --adapter <name>         Use specific adapter (pi, a2a, echo)
  --dashboard <url>        Dashboard URL (default: \$MAE_DASHBOARD_URL or http://localhost:8400)
  --dry-run                Use echo adapter (no real agents, test the flow)
  --cwd <path>             Working directory for agents
  --a2a-url <url>          Remote A2A agent endpoint
  --a2a-token <token>      Bearer token for A2A auth

Examples:
  mae task "Add input validation to the login form"
  mae chain full-stack-specialized "Build user settings page"
  mae run review "git diff HEAD~3"
  mae task "Fix the auth bug" --adapter pi
  mae task "review this PR" --adapter a2a --a2a-url http://agent-host:41271
  mae setup a2a --standard
  mae setup a2a --url http://agent-host:41271
  mae info
  mae session list

Config:
  ~/.mae/config            Sourced on every invocation (created by 'mae install')
  ~/.mae/repo              Repo-backed install root for engine/config files
  Defaults:
    MAE_DASHBOARD_URL      http://localhost:8400
    DATABASE_URL           postgres://mae:mae@localhost:5432/mae?sslmode=disable
    MAE_API_URL            http://localhost:8400
    MAE_LLM_GATEWAY_URL    unset unless provided
    LANGFUSE_HOST          unset unless provided

Environment (override config):
  MAE_DASHBOARD_URL   Dashboard API
  DATABASE_URL        PostgreSQL connection string
  MAE_API_URL         Vite dev proxy target
  MAE_TRACE_DIR       Trace directory (default: \$MAE_HOME/traces)
  MAE_LLM_GATEWAY_URL LiteLLM/OpenAI-compatible gateway
  MAE_LLM_GATEWAY_KEY LiteLLM/OpenAI-compatible gateway API key
  MAE_ROOT            Override repo location
  MAE_HOME            Install directory (default: ~/.mae)
  MAE_REF             Git ref used by install (default: main)
  MAE_UPDATE_REF      Branch used by update from a tag install (default: main)
  MAE_GIT_URL         Git URL used by install (default: https://github.com/${MAE_REPO}.git)
  MAE_REQUIRE_PI      Require 'pi' during install (default: 1; set 0 for echo/A2A-only)
  MAE_BIN             CLI install path (default: \$HOME/.local/bin/mae)
  MAE_API_TOKEN       API auth token
  MAE_A2A_DEFAULT_HOST Standard A2A host (unset; see .env.example)
  MAE_A2A_DEFAULT_PORT Standard A2A port (default: 41271)
  MAE_A2A_URL         Default A2A endpoint
  MAE_A2A_TOKEN       A2A bearer token
  LANGFUSE_PUBLIC_KEY Langfuse public key
  LANGFUSE_SECRET_KEY Langfuse secret key
  LANGFUSE_HOST       Langfuse host URL
HELP
}

# ── Main dispatch ────────────────────────────────────────────────────
case "${1:-}" in
  -h|--help|help)
    do_help
    exit 0
    ;;
  install)
    shift
    do_install "$@"
    ;;
  update)
    do_update
    ;;
  uninstall)
    do_uninstall
    ;;
  setup)
    shift
    do_setup "$@"
    exit 0
    ;;
  dashboard)
    shift
    do_dashboard "$@"
    exit 0
    ;;
  config)
    if [[ "${2:-}" == "edit" ]]; then
      ${EDITOR:-vi} "$MAE_CONFIG"
      exit 0
    fi
    # Forward to TypeScript CLI for interactive TUI, JSON in/out, discover
    root="$(find_mae_root)" || {
      echo "MAE not found. Run: mae install"
      exit 1
    }
    shift
    exec bun "$root/engine/cli.ts" config "$@"
    ;;
  *)
    # All other commands: forward to the bun CLI
    root="$(find_mae_root)" || {
      echo "MAE not found. Run: mae install"
      echo "Or set MAE_ROOT to your checkout."
      exit 1
    }
    export MAE_ROOT="$root"
    export MAE_DASHBOARD_URL DATABASE_URL MAE_API_URL MAE_TRACE_DIR MAE_LLM_GATEWAY_URL MAE_LLM_GATEWAY_KEY
    export MAE_API_TOKEN MAE_DEFAULT_ADAPTER MAE_A2A_URL MAE_A2A_TOKEN
    export LANGFUSE_PUBLIC_KEY LANGFUSE_SECRET_KEY LANGFUSE_HOST
    exec bun run "$root/engine/cli.ts" "$@"
    ;;
esac
