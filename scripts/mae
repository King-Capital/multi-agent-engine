#!/usr/bin/env bash
set -euo pipefail

# mae -- Multi-Agent Engine CLI
# Install: curl -fsSL https://raw.githubusercontent.com/King-Capital/multi-agent-engine/main/scripts/mae | bash -s install
# Or:      mae install

MAE_VERSION="1.0.0_RC1"
MAE_REPO="King-Capital/multi-agent-engine"
MAE_GIT_URL="git@github.com:${MAE_REPO}.git"
MAE_INSTALL_DIR="${MAE_HOME:-$HOME/.mae}"
MAE_CONFIG="$MAE_INSTALL_DIR/config"
MAE_BIN="${HOME}/.local/bin/mae"

# ── Load config (created during install, user-editable) ─────────────
if [[ -f "$MAE_CONFIG" ]]; then
  # shellcheck source=/dev/null
  source "$MAE_CONFIG"
fi

# Apply defaults for anything not set by config or env
MAE_DASHBOARD_URL="${MAE_DASHBOARD_URL:-http://localhost:8400}"
DATABASE_URL="${DATABASE_URL:-postgres://mae:mae@localhost:5432/mae?sslmode=disable}"
MAE_API_URL="${MAE_API_URL:-http://localhost:8400}"
export MAE_DASHBOARD_URL DATABASE_URL MAE_API_URL

# ── Locate MAE root ──────────────────────────────────────────────────
find_mae_root() {
  # 1. MAE_ROOT env var
  if [[ -n "${MAE_ROOT:-}" ]] && [[ -f "$MAE_ROOT/engine/cli.ts" ]]; then
    echo "$MAE_ROOT"; return
  fi
  # 2. Installed location
  if [[ -f "$MAE_INSTALL_DIR/engine/cli.ts" ]]; then
    echo "$MAE_INSTALL_DIR"; return
  fi
  # 3. Walk up from script location (dev checkout)
  local dir="$(cd "$(dirname "$0")" && pwd)"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/engine/cli.ts" ]] && [[ -f "$dir/VERSION" ]]; then
      echo "$dir"; return
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

# ── Check dependencies ───────────────────────────────────────────────
check_deps() {
  local missing=()
  command -v bun >/dev/null 2>&1 || missing+=("bun")
  command -v git >/dev/null 2>&1 || missing+=("git")
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Missing dependencies: ${missing[*]}"
    if [[ " ${missing[*]} " == *" bun "* ]]; then
      echo "Install bun: curl -fsSL https://bun.sh/install | bash"
    fi
    exit 1
  fi
}

# ── Install ──────────────────────────────────────────────────────────
do_install() {
  local dry_run=false
  if [[ "${1:-}" == "--dry-run" ]]; then
    dry_run=true
    echo "DRY RUN -- showing what would happen (no changes made)"
    echo ""
  fi

  check_deps

  echo "Install target: $MAE_INSTALL_DIR"
  echo ""

  if [[ -d "$MAE_INSTALL_DIR/.git" ]]; then
    echo "MAE already installed at $MAE_INSTALL_DIR"
    echo "Run 'mae update' to pull latest."
    exit 0
  fi

  # Step 1: Clone
  echo "[1/4] Clone $MAE_REPO → $MAE_INSTALL_DIR"
  if ! $dry_run; then
    git clone "$MAE_GIT_URL" "$MAE_INSTALL_DIR" 2>&1
  fi

  # Step 2: Engine deps
  echo "[2/4] Install engine dependencies (bun install)"
  if ! $dry_run; then
    cd "$MAE_INSTALL_DIR/engine" && bun install
  fi

  # Step 3: Config
  if [[ -f "$MAE_CONFIG" ]] && ! $dry_run; then
    echo "[3/4] Config exists at $MAE_CONFIG (keeping current)"
  else
    echo "[3/4] Create config: $MAE_CONFIG"
    echo "      MAE_DASHBOARD_URL = http://localhost:8400"
    echo "      DATABASE_URL      = postgres://mae:mae@localhost:5432/mae"
    echo "      MAE_API_URL       = http://localhost:8400"
    if ! $dry_run; then
      cat > "$MAE_CONFIG" << 'CONF'
# MAE Configuration -- edit these values for your environment
# Sourced by the mae CLI on every invocation

# Dashboard / Go API server
MAE_DASHBOARD_URL="http://localhost:8400"

# PostgreSQL connection (used by Go dashboard)
DATABASE_URL="postgres://mae:mae@localhost:5432/mae?sslmode=disable"

# API URL for dashboard-next Vite proxy
MAE_API_URL="http://localhost:8400"

# Default adapter (pi, a2a, echo)
# MAE_DEFAULT_ADAPTER="pi"

# API auth token (set if dashboard requires auth)
# MAE_API_TOKEN=""

# Default A2A endpoint (for remote agent delegation)
# MAE_A2A_URL=""
CONF
    fi
  fi

  # Step 4: CLI binary
  echo "[4/4] Install CLI: $MAE_BIN"
  if ! $dry_run; then
    mkdir -p "$(dirname "$MAE_BIN")"
    cp "$MAE_INSTALL_DIR/scripts/mae" "$MAE_BIN"
    chmod +x "$MAE_BIN"
  fi

  echo ""
  if $dry_run; then
    echo "DRY RUN complete. Run 'mae install' to execute."
  else
    echo "✓ MAE installed (engine only -- no frontend)"
    echo "  Root:      $MAE_INSTALL_DIR"
    echo "  Config:    $MAE_CONFIG"
    echo "  CLI:       $MAE_BIN"
    echo "  Dashboard: $MAE_DASHBOARD_URL"
    echo "  Database:  $DATABASE_URL"
    echo ""
    echo "Edit $MAE_CONFIG to customize. Then try: mae info"
    echo "To install the dashboard frontend: mae dashboard install"
  fi
}

# ── Dashboard management (opt-in) ──────────────────────────────────
do_dashboard() {
  local root
  root="$(find_mae_root)" || { echo "MAE not found. Run 'mae install' first."; exit 1; }

  local subcmd="${1:-help}"
  case "$subcmd" in
    install)
      echo "Installing dashboard-next frontend..."
      cd "$root/dashboard-next" && bun install
      echo "✓ Frontend deps installed."
      echo "  Start dev server: mae dashboard dev"
      echo "  Build for prod:   mae dashboard build"
      ;;
    dev)
      echo "Starting dashboard-next dev server (proxying to $MAE_API_URL)..."
      cd "$root/dashboard-next" && MAE_API_URL="$MAE_API_URL" bun run dev
      ;;
    build)
      echo "Building dashboard-next for production..."
      cd "$root/dashboard-next" && bun run build
      echo "✓ Built to dashboard-next/dist/"
      ;;
    *)
      local installed="no"
      [[ -d "$root/dashboard-next/node_modules" ]] && installed="yes"
      echo "MAE Dashboard Frontend"
      echo "  Installed: $installed"
      echo "  API:       $MAE_API_URL"
      echo "  Database:  $DATABASE_URL"
      echo ""
      echo "Commands:"
      echo "  mae dashboard install   Install frontend dependencies"
      echo "  mae dashboard dev       Start Vite dev server (port 5173)"
      echo "  mae dashboard build     Build for production to dist/"
      ;;
  esac
}

# ── Update ───────────────────────────────────────────────────────────
do_update() {
  local root
  root="$(find_mae_root)" || { echo "MAE not found. Run 'mae install' first."; exit 1; }

  echo "Updating MAE at $root..."

  cd "$root"
  local before=$(git rev-parse HEAD)
  git pull --ff-only 2>&1
  local after=$(git rev-parse HEAD)

  if [[ "$before" == "$after" ]]; then
    echo "Already up to date."
  else
    echo "Updated: $(git log --oneline ${before}..${after} | wc -l | tr -d ' ') new commits"
    git log --oneline "${before}..${after}"
  fi

  # Reinstall engine deps in case they changed
  echo "Updating engine dependencies..."
  cd "$root/engine" && bun install

  # Update the CLI script itself
  if [[ -f "$MAE_BIN" ]]; then
    cp "$root/scripts/mae" "$MAE_BIN"
    chmod +x "$MAE_BIN"
    echo "CLI updated."
  fi

  echo ""
  echo "✓ MAE updated"
  local ver=$(cat "$root/VERSION" 2>/dev/null || echo "unknown")
  echo "  Version: $ver"
}

# ── Uninstall ────────────────────────────────────────────────────────
do_uninstall() {
  echo "Uninstalling MAE..."
  if [[ -f "$MAE_BIN" ]]; then
    rm "$MAE_BIN"
    echo "Removed $MAE_BIN"
  fi
  if [[ -d "$MAE_INSTALL_DIR" ]]; then
    read -p "Remove $MAE_INSTALL_DIR? [y/N] " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
      rm -rf "$MAE_INSTALL_DIR"
      echo "Removed $MAE_INSTALL_DIR"
    fi
  fi
  echo "✓ MAE uninstalled"
}

# ── Help ─────────────────────────────────────────────────────────────
do_help() {
  cat <<HELP
mae -- Multi-Agent Engine CLI v${MAE_VERSION}

Lifecycle:
  mae install              Clone repo, install engine deps, create config
  mae install --dry-run    Preview install steps without making changes
  mae update               Pull latest, reinstall deps, update CLI
  mae uninstall            Remove CLI and optionally the repo

Dashboard (opt-in):
  mae dashboard            Show dashboard status
  mae dashboard install    Install frontend deps (dashboard-next)
  mae dashboard dev        Start Vite dev server (port 5173)
  mae dashboard build      Build frontend for production

Run swarms:
  mae task <description>   Run plan-build-review on a task (default chain)
  mae chain <name> <task>  Run a specific chain
  mae run <prompt> [args]  Run a reusable prompt workflow

Chains:
  plan-build-review        Plan → build → validate (default)
  full-stack-specialized   Frontend + Backend + Systems + QA + Security leads
  backend-only             Backend + QA + Security
  frontend-only            Frontend + QA
  review-only              Red + Blue team code review
  build-verify             Builder-verifier loop with escalation

Sessions:
  mae session list         List all sessions
  mae session close <id>   Close a session (--status done|error)

Info:
  mae info                 System overview (chains, adapters, routing, health)
  mae version              Version and connection info
  mae adapters             List available adapters
  mae discover <url>       Discover a remote A2A agent
  mae config               Show current config
  mae config edit          Open config in \$EDITOR

Agents:
  mae new-agent <name> <role> <team>   Scaffold a new agent persona

Options:
  --adapter <name>         Use specific adapter (pi, a2a, echo)
  --dashboard <url>        Dashboard URL (default: \$MAE_DASHBOARD_URL or http://localhost:8400)
  --dry-run                Use echo adapter (no real agents, test the flow)
  --cwd <path>             Working directory for agents
  --a2a-url <url>          Remote A2A agent endpoint
  --a2a-token <token>      Bearer token for A2A auth

Examples:
  mae task "Add input validation to the login form"
  mae chain full-stack-specialized "Build user settings page"
  mae run review "git diff HEAD~3"
  mae task "Fix the auth bug" --adapter pi
  mae task "review this PR" --adapter a2a --a2a-url http://agent-host:41271
  mae info
  mae session list

Config:
  ~/.mae/config            Sourced on every invocation (created by 'mae install')
  Defaults:
    MAE_DASHBOARD_URL      http://localhost:8400
    DATABASE_URL           postgres://mae:mae@localhost:5432/mae
    MAE_API_URL            http://localhost:8400

Environment (override config):
  MAE_DASHBOARD_URL   Dashboard API
  DATABASE_URL        PostgreSQL connection string
  MAE_API_URL         Vite dev proxy target
  MAE_ROOT            Override repo location
  MAE_HOME            Install directory (default: ~/.mae)
  MAE_API_TOKEN       API auth token
  MAE_A2A_URL         Default A2A endpoint
HELP
}

# ── Main dispatch ────────────────────────────────────────────────────
case "${1:-}" in
  -h|--help|help)
    do_help
    exit 0
    ;;
  install)
    shift
    do_install "$@"
    ;;
  update)
    do_update
    ;;
  uninstall)
    do_uninstall
    ;;
  dashboard)
    shift
    do_dashboard "$@"
    exit 0
    ;;
  config)
    if [[ "${2:-}" == "edit" ]]; then
      ${EDITOR:-vi} "$MAE_CONFIG"
      exit 0
    fi
    # Forward to TypeScript CLI for interactive TUI, JSON in/out, discover
    root="$(find_mae_root)" || {
      echo "MAE not found. Run: mae install"
      exit 1
    }
    shift
    exec bun "$root/engine/cli.ts" config "$@"
    ;;
  *)
    # All other commands: forward to the bun CLI
    root="$(find_mae_root)" || {
      echo "MAE not found. Run: mae install"
      echo "Or set MAE_ROOT to your checkout."
      exit 1
    }
    export MAE_ROOT="$root"
    export MAE_DASHBOARD_URL DATABASE_URL MAE_API_URL
    exec bun run "$root/engine/cli.ts" "$@"
    ;;
esac
