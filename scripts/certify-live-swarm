#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<USAGE
Usage: scripts/certify-live-swarm [--live-pi] [--dashboard-url URL] [--only clean|seeded|failing]

Runs MAE production certification checks:
  1. dashboard health/SSE smoke
  2. clean fixture review should avoid actual P0/P1 blocker findings
  3. seeded security fixture should produce P0/P1 command-injection evidence
  4. deterministic failing fixture must not be marked ready by MAE

Default adapter is echo for cheap CI smoke. --live-pi uses the real Pi adapter.
Echo mode is a plumbing smoke only; production certification requires --live-pi.
USAGE
}

live_pi=0
dashboard_url="${MAE_DASHBOARD_URL:-http://127.0.0.1:8400}"
only_fixture="all"
adapter="echo"
root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
workdir=""
trace_dir=""
certification_done=0

log() { printf '\n==> %s\n' "$*" >&2; }
fail() { echo "CERTIFICATION FAILED: $*" >&2; exit 1; }

require_tool() {
  command -v "$1" >/dev/null 2>&1 || fail "required tool missing: $1"
}

lower_line_contains_blocker() {
  awk '
    {
      line = tolower($0)
      if (line ~ /(no|zero)[[:space:]]+(p0|p1|critical|high)/) next
      severity = line ~ /(^|[^a-z])(p0|p1|critical|high)([^a-z]|$)/
      signal = line ~ /(finding|blocker|fail|vulnerab|issue|risk|bug|exploit|command|injection|unsafe)/
      if (severity && signal) found = 1
    }
    END { exit found ? 0 : 1 }
  ' "$1"
}

has_actual_blocker() {
  local file="$1"
  lower_line_contains_blocker "$file"
}

has_seeded_command_injection_evidence() {
  local file="$1"
  awk '
    {
      line = tolower($0)
      severity = line ~ /(^|[^a-z])(p0|p1)([^a-z]|$)/
      evidence = line ~ /(command[ -]?injection|exec\(|child_process|nslookup)/
      if (severity && evidence) found = 1
    }
    END { exit found ? 0 : 1 }
  ' "$file"
}

marks_certification_ready() {
  local file="$1"
  awk '
    {
      raw = $0
      line = tolower($0)
      negated = line ~ /(not[[:space:]]+certification[[:space:]]+ready|not[[:space:]]+ready[[:space:]]+for[[:space:]]+certification|certification[[:space:]_]+ready[[:space:]]*:[[:space:]]*false|certification_ready:[[:space:]]*false|lacks[[:space:]]+the[[:space:]]+required[[:space:]]+readiness[[:space:]]+marker|lacks[[:space:]]+certification_ready|missing[[:space:]]+certification_ready)/
      if (!negated && raw ~ /^CERTIFICATION_READY$/) found = 1
      if (!negated && line ~ /^(certification[[:space:]]+ready|ready[[:space:]]+for[[:space:]]+certification)[[:space:].:!-]*(true|yes|pass|passed)?[[:space:]]*$/) found = 1
    }
    END { exit found ? 0 : 1 }
  ' "$file"
}

extract_session_id() {
  grep -Eho 'Session [0-9a-f-]{36} completed|session_id":"[0-9a-f-]{36}' "$@" \
    | grep -Eo '[0-9a-f-]{36}' \
    | tail -1 || true
}

trace_file_for_session() {
  local session_id="$1"
  echo "$trace_dir/$session_id.jsonl"
}

artifact_path_for_ref() {
  local session_id="$1"
  local artifact_ref="$2"
  [[ -n "$artifact_ref" ]] || return 1
  [[ "$artifact_ref" != /* && "$artifact_ref" != *..* ]] || return 1
  [[ "$artifact_ref" == "$session_id/artifacts/"* ]] || return 1
  local artifact_path="$trace_dir/$artifact_ref"
  local artifact_root="$trace_dir/$session_id/artifacts"
  [[ -f "$artifact_path" && -d "$artifact_root" && ! -L "$artifact_path" && ! -L "$artifact_root" ]] || return 1
  local resolved_artifact resolved_root
  resolved_artifact="$(cd "$(dirname "$artifact_path")" && pwd -P)/$(basename "$artifact_path")"
  resolved_root="$(cd "$artifact_root" && pwd -P)"
  [[ "$resolved_artifact" == "$resolved_root/"* ]] || return 1
  printf '%s\n' "$artifact_path"
}

unsuperseded_agent_failures() {
  local trace_file="$1"
  [[ -f "$trace_file" ]] || return 0
  jq -s -r '
    def agent_id: (.agent_id // .data.agent_id // "");
    def grade: (.grade // .data.grade // "");
    def failed: (grade | test("^(FAILED|ERROR)$"; "i"));
    def agent_end: (.type == "agent.end" or .event_type == "agent_done");
    [ .[] | select(agent_end) | {agent_id: agent_id, grade: grade} ] as $events
    | [
        range(0; $events | length) as $i
        | $events[$i] as $event
        | select(
            ($event.agent_id != "") and
            ($event.grade | test("^(FAILED|ERROR)$"; "i")) and
            ([
              range($i + 1; $events | length) as $j
              | $events[$j]
              | select(
                  .agent_id == $event.agent_id and
                  ((.grade | test("^(FAILED|ERROR)$"; "i")) | not)
                )
            ] | length == 0)
          )
      ]
    | length
  ' "$trace_file"
}

trace_has_operational_failures() {
  local trace_file="$1"
  [[ -f "$trace_file" ]] || return 1
  jq -e '
    select(
      .type == "agent.error" or
      .event_type == "worker_failed" or
      .event_type == "error" or
      (.type == "session.end" and ((.status // "") | test("^(completed|success)$"; "i") | not))
    )
  ' "$trace_file" >/dev/null
}

unsuperseded_empty_output_artifacts() {
  local trace_file="$1"
  [[ -f "$trace_file" ]] || return 0
  jq -s -r '
    def agent_id: (.agent_id // .data.agent_id // "");
    def grade: (.grade // .data.grade // "");
    def artifact: (.output_artifact // .data.output_artifact // "");
    def failed: (grade | test("^(FAILED|ERROR)$"; "i"));
    def agent_end: (.type == "agent.end" or .event_type == "agent_done");
    [ .[] | select(agent_end) | {agent_id: agent_id, grade: grade, artifact: artifact} ] as $events
    | range(0; $events | length) as $i
    | $events[$i] as $event
    | select(
        ($event.artifact != "") and
        ([
          range($i + 1; $events | length) as $j
          | $events[$j]
          | select(
              .agent_id == $event.agent_id and
              ((.grade | test("^(FAILED|ERROR)$"; "i")) | not)
            )
        ] | length == 0)
      )
    | $event.artifact
  ' "$trace_file" | while IFS= read -r artifact_ref; do
    local artifact_path
    artifact_path="$(artifact_path_for_ref "$(basename "$trace_file" .jsonl)" "$artifact_ref" || true)"
    [[ -n "$artifact_path" ]] || continue
    if grep -q 'ERROR: Empty output' "$artifact_path"; then
      printf '%s\n' "$artifact_ref"
    fi
  done
}

non_synthesis_contract_artifacts() {
  local trace_file="$1"
  [[ -f "$trace_file" ]] || return 0
  jq -r '
    select(.type == "agent.end" or .event_type == "agent_done")
    | select(
        (((.agent_id // .data.agent_id // "") | startswith("synth-")) | not) and
        ((.team // .data.team_name // "") != "Synthesis") and
        ((.agent_id // .data.agent_id // "") != "pi-orchestrator") and
        ((.agent_id // .data.agent_id // "") != "echo-orchestrator")
      )
    | (.output_artifact // .data.output_artifact // empty)
  ' "$trace_file" | while IFS= read -r artifact_ref; do
    local artifact_path
    artifact_path="$(artifact_path_for_ref "$(basename "$trace_file" .jsonl)" "$artifact_ref" || true)"
    [[ -n "$artifact_path" ]] || continue
    grep -q 'CERTIFICATION_CONTRACT:' "$artifact_path" && printf '%s\n' "$artifact_ref"
  done
}

missing_required_review_leads() {
  local trace_file="$1"
  [[ -f "$trace_file" ]] || return 0

  local required=(
    "Correctness Review:pi-correctness-lead"
    "Adversarial Review:pi-adversarial-lead"
    "Quality Review:pi-quality-lead"
    "Security Review:pi-security-lead"
    "Domain Review:pi-domain-lead"
  )

  local entry team lead_id
  for entry in "${required[@]}"; do
    team="${entry%%:*}"
    lead_id="${entry#*:}"
    if ! jq -e --arg team "$team" --arg lead_id "$lead_id" '
      def aid: (.agent_id // .data.agent_id // "");
      def team_name: (.team // .data.team_name // "");
      select(.type == "agent.end" or .event_type == "agent_done")
      | select((aid == $lead_id) or (team_name == $team and (aid | test("-lead$"))))
    ' "$trace_file" >/dev/null; then
      printf '%s\n' "$team"
    fi
  done
}

canonical_artifact_from_trace() {
  local session_id="$1"
  local trace_file
  trace_file="$(trace_file_for_session "$session_id")"
  [[ -f "$trace_file" ]] || return 1

  local candidates
  candidates="$(jq -r '
    select(.type == "agent.end" or .event_type == "agent_done")
    | select(
        ((.agent_id // .data.agent_id // "") | startswith("synth-")) or
        ((.team // .data.team_name // "") == "Synthesis") or
        ((.agent_id // .data.agent_id // "") == "pi-orchestrator") or
        ((.agent_id // .data.agent_id // "") == "echo-orchestrator")
      )
    | (.output_artifact // .data.output_artifact // empty)
  ' "$trace_file")"

  [[ -z "$candidates" ]] && return 1

  local ref
  while IFS= read -r ref; do
    local artifact_path
    artifact_path="$(artifact_path_for_ref "$session_id" "$ref" || true)"
    [[ -n "$artifact_path" ]] || continue
    if grep -q 'CERTIFICATION_CONTRACT:' "$artifact_path" && grep -q 'END_CERTIFICATION_CONTRACT' "$artifact_path"; then
      echo "$ref"
      return 0
    fi
  done <<< "$candidates"

  echo "$candidates" | tail -1
}

review_report_path() {
  local session_id="$1"
  local fallback="$2"
  local artifact_ref=""
  local report=""

  artifact_ref="$(canonical_artifact_from_trace "$session_id" || true)"
  local artifact_path
  artifact_path="$(artifact_path_for_ref "$session_id" "$artifact_ref" || true)"
  if [[ -n "$artifact_path" ]]; then
    echo "$artifact_path"
    return 0
  fi

  if [[ "$adapter" == "pi" ]]; then
    return 1
  fi

  report="$(find "$trace_dir/$session_id/artifacts" -maxdepth 1 \( -name 'synth-*-output-*.txt' -o -name '*orchestrator-output-*.txt' \) -type f -print0 2>/dev/null | xargs -0 ls -t 2>/dev/null | head -1 || true)"
  if [[ -n "$report" ]]; then
    echo "$report"
    return 0
  fi

  echo "$fallback"
}

validate_validation_contract() {
  local file="$1"
  awk '
    BEGIN { in_block = 0 }
    /VALIDATION_CONTRACT:/ { in_block = 1; found = 1; next }
    /END_VALIDATION_CONTRACT/ { in_block = 0; ended = 1; next }
    in_block {
      line = tolower($0)
      if (line ~ /^schema_version:[[:space:]]*1[[:space:]]*$/) schema = 1
      if (line ~ /^session_id:[[:space:]]*[^[:space:]]+[[:space:]]*$/) session_id = 1
      if (line ~ /^trace_ref:[[:space:]]*[^[:space:]]+[[:space:]]*$/) trace_ref = 1
      if (line ~ /^artifact_ref:[[:space:]]*[^[:space:]]+[[:space:]]*$/) artifact_ref = 1
      if (line ~ /^validated:[[:space:]]*(true|false)[[:space:]]*$/) validated = line
      if (line ~ /^evidence_complete:[[:space:]]*(true|false)[[:space:]]*$/) evidence_complete = line
      if (line ~ /^lifecycle_valid:[[:space:]]*(true|false)[[:space:]]*$/) lifecycle_valid = line
      if (line ~ /^contract_matches_evidence:[[:space:]]*(true|false)[[:space:]]*$/) contract_matches_evidence = line
      if (line ~ /^scope_valid:[[:space:]]*(true|false)[[:space:]]*$/) scope_valid = line
      if (line ~ /^steering_valid:[[:space:]]*(true|false)[[:space:]]*$/) steering_valid = line
      if (line ~ /^spawn_policy_valid:[[:space:]]*(true|false)[[:space:]]*$/) spawn_policy_valid = line
      if (line ~ /^blocking_reasons:/) blocking_reasons = line
    }
    END {
      ok = found && ended && schema && session_id && trace_ref && artifact_ref && validated && evidence_complete && lifecycle_valid && contract_matches_evidence && scope_valid && steering_valid && spawn_policy_valid && blocking_reasons
      no_blockers = blocking_reasons ~ /^blocking_reasons:[[:space:]]*none[[:space:]]*$/
      components_true = evidence_complete ~ /true/ && lifecycle_valid ~ /true/ && contract_matches_evidence ~ /true/ && scope_valid ~ /true/ && steering_valid ~ /true/ && spawn_policy_valid ~ /true/
      components_false = evidence_complete ~ /false/ || lifecycle_valid ~ /false/ || contract_matches_evidence ~ /false/ || scope_valid ~ /false/ || steering_valid ~ /false/ || spawn_policy_valid ~ /false/
      ok = ok && ((validated ~ /true/ && components_true && no_blockers) || (validated ~ /false/ && components_false && !no_blockers))
      exit ok ? 0 : 1
    }
  ' "$file"
}

validate_certification_contract() {
  local file="$1"
  local expected="$2"
  awk -v expected="$expected" '
    BEGIN { in_block = 0 }
    /CERTIFICATION_CONTRACT:/ { in_block = 1; found = 1; next }
    /END_CERTIFICATION_CONTRACT/ { in_block = 0; ended = 1; next }
    in_block {
      line = tolower($0)
      if (line ~ /^schema_version:[[:space:]]*1[[:space:]]*$/) schema = 1
      if (line ~ /^verdict:[[:space:]]*(pass|fail)[[:space:]]*$/) verdict = line
      if (line ~ /^p0_count:[[:space:]]*[0-9]+[[:space:]]*$/) p0 = line
      if (line ~ /^p1_count:[[:space:]]*[0-9]+[[:space:]]*$/) p1 = line
      if (line ~ /^perspectives_covered:/) perspectives = line
      if (line ~ /^blockers:/) blockers = line
      if (line ~ /^failed_teams:/) failed_teams = line
      if (line ~ /^certification_ready:[[:space:]]*(true|false)[[:space:]]*$/) ready = line
    }
    END {
      ok = found && ended && schema && verdict && p0 && p1 && perspectives && blockers && failed_teams && ready
      ok = ok && perspectives ~ /correctness/ && perspectives ~ /adversarial/ && perspectives ~ /quality/ && perspectives ~ /security/ && perspectives ~ /domain/
      if (expected == "clean") ok = ok && failed_teams ~ /^failed_teams:[[:space:]]*none[[:space:]]*$/
      if (expected == "clean") ok = ok && blockers ~ /^blockers:[[:space:]]*none[[:space:]]*$/
      if (expected == "clean") ok = ok && verdict ~ /pass/ && p0 ~ /:[[:space:]]*0[[:space:]]*$/ && p1 ~ /:[[:space:]]*0[[:space:]]*$/ && ready ~ /true/
      if (expected == "seeded") ok = ok && verdict ~ /fail/ && (p0 !~ /:[[:space:]]*0[[:space:]]*$/ || p1 !~ /:[[:space:]]*0[[:space:]]*$/) && ready ~ /false/
      if (expected == "failing") ok = ok && verdict ~ /fail/ && ready ~ /false/
      exit ok ? 0 : 1
    }
  ' "$file"
}

validation_bool() {
  local value="$1"
  [[ "$value" == 1 ]] && printf 'false' || printf 'true'
}

join_validation_reasons() {
  local reasons_file="$1"
  if [[ ! -s "$reasons_file" ]]; then
    printf 'none'
    return 0
  fi
  paste -sd ';' "$reasons_file" | sed 's/[[:space:]]\+/ /g; s/; */; /g'
}

review_report_has_blocking_findings() {
  local file="$1"
  awk '
    {
      line = tolower($0)
      if (line ~ /^verdict:[[:space:]]*fail[[:space:]]*$/) found = 1
      if (line ~ /^blockers:[[:space:]]*/ && line !~ /^blockers:[[:space:]]*(none|no blockers)[[:space:]]*$/) found = 1
      if (line ~ /(^|[^a-z])(p0|p1|critical|high)([^a-z]|$)/ && line ~ /(finding|blocker|fail|vulnerab|issue|risk|bug|exploit|command|injection|unsafe)/) found = 1
    }
    END { exit found ? 0 : 1 }
  ' "$file"
}

validate_review_report_contract() {
  local file="$1"
  awk '
    {
      line = tolower($0)
      if (line ~ /^review_report:/) found = 1
      if (line ~ /^scope:[[:space:]]*[^[:space:]]/) scope = 1
      if (line ~ /^commands_run:[[:space:]]*[^[:space:]]/) commands = 1
      if (line ~ /^findings:[[:space:]]*[^[:space:]]/) findings = 1
      if (line ~ /^blockers:[[:space:]]*[^[:space:]]/) blockers = 1
      if (line ~ /^verdict:[[:space:]]*(pass|fail)[[:space:]]*$/) verdict = 1
    }
    END { exit (found && scope && commands && findings && blockers && verdict) ? 0 : 1 }
  ' "$file"
}

required_lead_review_report_failures() {
  local trace_file="$1"
  [[ -f "$trace_file" ]] || return 0
  local session_id
  session_id="$(basename "$trace_file" .jsonl)"

  jq -r '
    def aid: (.agent_id // .data.agent_id // "");
    def team_name: (.team // .data.team_name // "");
    select(.type == "agent.end" or .event_type == "agent_done")
    | select((aid | test("-lead$")) or (team_name | test(" Review$")))
    | select((team_name | test("^(Correctness|Adversarial|Quality|Security|Domain) Review$")) or (aid | test("^pi-(correctness|adversarial|quality|security|domain)-lead$")))
    | [team_name, aid, (.output_artifact // .data.output_artifact // "")]
    | @tsv
  ' "$trace_file" | while IFS=$'\t' read -r team_name agent_id artifact_ref; do
    if [[ -z "$artifact_ref" ]]; then
      printf '%s missing REVIEW_REPORT artifact reference\n' "${team_name:-$agent_id}"
      continue
    fi
    local artifact_path
    artifact_path="$(artifact_path_for_ref "$session_id" "$artifact_ref" || true)"
    if [[ -z "$artifact_path" ]]; then
      printf '%s invalid or missing artifact %s\n' "${team_name:-$agent_id}" "$artifact_ref"
      continue
    fi
    validate_review_report_contract "$artifact_path" || printf '%s artifact lacks valid REVIEW_REPORT contract: %s\n' "${team_name:-$agent_id}" "$artifact_ref"
  done
}

blocking_review_report_artifacts() {
  local trace_file="$1"
  [[ -f "$trace_file" ]] || return 0
  local session_id
  session_id="$(basename "$trace_file" .jsonl)"
  jq -r '
    def aid: (.agent_id // .data.agent_id // "");
    def team_name: (.team // .data.team_name // "");
    select(.type == "agent.end" or .event_type == "agent_done")
    | select((team_name | test("^(Correctness|Adversarial|Quality|Security|Domain) Review$")) or (aid | test("^pi-(correctness|adversarial|quality|security|domain)-lead$")))
    | (.output_artifact // .data.output_artifact // empty)
  ' "$trace_file" | while IFS= read -r artifact_ref; do
    local artifact_path
    artifact_path="$(artifact_path_for_ref "$session_id" "$artifact_ref" || true)"
    [[ -n "$artifact_path" ]] || continue
    if validate_review_report_contract "$artifact_path" && review_report_has_blocking_findings "$artifact_path"; then
      printf '%s\n' "$artifact_ref"
    fi
  done
}

run_deterministic_validator() {
  local session_id="$1"
  local fixture_name="$2"
  local cert_report="$3"
  local trace_file
  trace_file="$(trace_file_for_session "$session_id")"
  local validator_report="$trace_dir/$session_id.validation.txt"
  local reasons_file="$trace_dir/$session_id.validation.reasons"
  : > "$reasons_file"

  [[ -f "$trace_file" ]] || printf 'missing trace file: %s\n' "$trace_file" >> "$reasons_file"
  [[ -f "$cert_report" ]] || printf 'missing certification artifact/report: %s\n' "$cert_report" >> "$reasons_file"

  local evidence_failure=0 lifecycle_failure=0 contract_failure=0 scope_failure=0 steering_failure=0 spawn_failure=0

  if [[ -f "$trace_file" ]]; then
    grep -q 'session' "$trace_file" || { printf 'trace lacks session events: %s\n' "$trace_file" >> "$reasons_file"; evidence_failure=1; }
    if trace_has_operational_failures "$trace_file"; then
      printf 'trace contains operational failure event: %s\n' "$trace_file" >> "$reasons_file"
      lifecycle_failure=1
    fi

    local missing_leads failed_agents leaked_contracts empty_outputs stale_participants steering_events review_report_failures blocking_reports repo_source_reads drift_count wrong_fixture_count worker_spawn_count missing_preview_count
    missing_leads="$({ missing_required_review_leads "$trace_file" || true; })"
    if [[ -n "$missing_leads" ]]; then
      printf 'missing required review lead(s): %s in %s\n' "$missing_leads" "$trace_file" >> "$reasons_file"
      lifecycle_failure=1
    fi

    failed_agents="$(unsuperseded_agent_failures "$trace_file" || true)"
    if [[ "$failed_agents" != "0" ]]; then
      printf 'unsuperseded failed agent completion(s): %s in %s\n' "$failed_agents" "$trace_file" >> "$reasons_file"
      lifecycle_failure=1
    fi

    leaked_contracts="$({ non_synthesis_contract_artifacts "$trace_file" || true; })"
    if [[ -n "$leaked_contracts" ]]; then
      printf 'CERTIFICATION_CONTRACT outside synthesis artifact(s): %s\n' "$leaked_contracts" >> "$reasons_file"
      contract_failure=1
    fi

    empty_outputs="$({ unsuperseded_empty_output_artifacts "$trace_file" || true; })"
    if [[ -n "$empty_outputs" ]]; then
      printf 'unsuperseded empty-output artifact(s): %s\n' "$empty_outputs" >> "$reasons_file"
      evidence_failure=1
    fi

    stale_participants="$(jq -r '
      select(.type == "participant.stale" or .event_type == "participant_stale" or .event_type == "participant.stale")
      | (.participant_id // .data.participant_id // .agent_id // .data.agent_id // "unknown")
    ' "$trace_file")"
    if [[ -n "$stale_participants" ]]; then
      printf 'stale/offline participant event(s): %s\n' "$stale_participants" >> "$reasons_file"
      lifecycle_failure=1
    fi

    steering_events="$(jq -r '
      def kind: (.kind // .data.kind // "");
      def event_type: (.event_type // .type // "");
      select((kind == "web-steer") or (kind == "cli-steer") or (event_type | test("steer|user_message|control")))
      | event_type
    ' "$trace_file")"
    if [[ -n "$steering_events" ]]; then
      printf 'unattended certification trace contains steering/control event(s): %s\n' "$steering_events" >> "$reasons_file"
      steering_failure=1
    fi

    review_report_failures="$({ required_lead_review_report_failures "$trace_file" || true; })"
    if [[ -n "$review_report_failures" ]]; then
      printf 'required review artifact schema failure(s): %s\n' "$review_report_failures" >> "$reasons_file"
      contract_failure=1
    fi

    blocking_reports="$({ blocking_review_report_artifacts "$trace_file" || true; })"
    if [[ -n "$blocking_reports" && "$fixture_name" == "clean" ]]; then
      printf 'clean fixture final contract conflicts with blocking review report artifact(s): %s\n' "$blocking_reports" >> "$reasons_file"
      contract_failure=1
    fi

    worker_spawn_count="$(jq -r '
      def aid: (.agent_id // .data.agent_id // "");
      select(
        (
          .type == "agent.start" and
          (aid != "") and
          ((aid | test("-lead$")) | not) and
          ((aid | startswith("synth-")) | not) and
          aid != "pi-orchestrator" and
          aid != "echo-orchestrator"
        ) or
        (.event_type == "agent_spawn" and ((.data.agent_role // "") == "worker"))
      )
      | aid // .id // "worker"
    ' "$trace_file" | wc -l | tr -d ' ')"
    if [[ "$worker_spawn_count" != "0" ]]; then
      printf 'lead-only certification spawned worker(s): %s in %s\n' "$worker_spawn_count" "$trace_file" >> "$reasons_file"
      spawn_failure=1
    fi

    missing_preview_count="$(jq -r 'select(.type == "tool.call") | select((.args_preview // "") == "")' "$trace_file" | wc -l | tr -d ' ')"
    if [[ "$missing_preview_count" != "0" ]]; then
      printf 'tool.call event(s) missing args_preview in certification mode: %s in %s\n' "$missing_preview_count" "$trace_file" >> "$reasons_file"
      scope_failure=1
    fi

    repo_source_reads="$(jq -r --arg root "$root" --arg workdir "$workdir" 'select(.type == "tool.call") | (.args_preview // "") | select((index($root) != null) and (index($workdir) == null))' "$trace_file" | wc -l | tr -d ' ')"
    if [[ "$repo_source_reads" != "0" ]]; then
      printf 'repository source read during fixture-only certification: %s call(s) in %s\n' "$repo_source_reads" "$trace_file" >> "$reasons_file"
      scope_failure=1
    fi

    drift_count="$(jq -r --arg workdir "$workdir" 'select(.type == "tool.call") | (.args_preview // "") | select(test("/mae-cert\\.[^/]+/") and (startswith($workdir) | not))' "$trace_file" | wc -l | tr -d ' ')"
    if [[ "$drift_count" != "0" ]]; then
      printf 'scope drift to previous certification workdir: %s call(s) in %s\n' "$drift_count" "$trace_file" >> "$reasons_file"
      scope_failure=1
    fi

    if [[ -n "$fixture_name" ]]; then
      wrong_fixture_count="$(jq -r --arg workdir "$workdir" --arg fixture "$fixture_name" 'select(.type == "tool.call") | (.args_preview // "") | select(startswith($workdir) and (test("/mae-cert\\.[^/]+/(clean|seeded|failing)(/|$)")) and (startswith($workdir + "/" + $fixture) | not))' "$trace_file" | wc -l | tr -d ' ')"
      if [[ "$wrong_fixture_count" != "0" ]]; then
        printf 'wrong fixture inspected for %s: %s call(s) in %s\n' "$fixture_name" "$wrong_fixture_count" "$trace_file" >> "$reasons_file"
        scope_failure=1
      fi
    fi
  else
    evidence_failure=1
    lifecycle_failure=1
    scope_failure=1
  fi

  if [[ -f "$cert_report" ]]; then
    validate_certification_contract "$cert_report" "$fixture_name" || { printf 'CERTIFICATION_CONTRACT does not match deterministic evidence for fixture %s: %s\n' "$fixture_name" "$cert_report" >> "$reasons_file"; contract_failure=1; }
    if [[ -f "$trace_file" ]]; then
      local canonical_ref canonical_path
      canonical_ref="$(canonical_artifact_from_trace "$session_id" || true)"
      canonical_path=""
      [[ -n "$canonical_ref" ]] && canonical_path="$(artifact_path_for_ref "$session_id" "$canonical_ref" || true)"
      if [[ -z "$canonical_ref" || -z "$canonical_path" ]]; then
        printf 'canonical synthesis artifact missing in trace: %s\n' "$trace_file" >> "$reasons_file"
        contract_failure=1
      elif [[ "$(cd "$(dirname "$canonical_path")" && pwd -P)/$(basename "$canonical_path")" != "$(cd "$(dirname "$cert_report")" && pwd -P)/$(basename "$cert_report")" ]]; then
        printf 'validator artifact is not canonical synthesis artifact: expected %s got %s\n' "$canonical_path" "$cert_report" >> "$reasons_file"
        contract_failure=1
      fi
    fi
  else
    contract_failure=1
  fi

  local evidence_complete lifecycle_valid contract_matches_evidence scope_valid steering_valid spawn_policy_valid validated blocking_reasons
  evidence_complete="$(validation_bool "$evidence_failure")"
  lifecycle_valid="$(validation_bool "$lifecycle_failure")"
  contract_matches_evidence="$(validation_bool "$contract_failure")"
  scope_valid="$(validation_bool "$scope_failure")"
  steering_valid="$(validation_bool "$steering_failure")"
  spawn_policy_valid="$(validation_bool "$spawn_failure")"
  blocking_reasons="$(join_validation_reasons "$reasons_file")"
  if [[ "$evidence_complete" == "true" && "$lifecycle_valid" == "true" && "$contract_matches_evidence" == "true" && "$scope_valid" == "true" && "$steering_valid" == "true" && "$spawn_policy_valid" == "true" ]]; then
    validated="true"
  else
    validated="false"
  fi

  {
    printf 'VALIDATION_CONTRACT:\n'
    printf 'schema_version: 1\n'
    printf 'session_id: %s\n' "$session_id"
    printf 'trace_ref: %s\n' "$trace_file"
    printf 'artifact_ref: %s\n' "$cert_report"
    printf 'validated: %s\n' "$validated"
    printf 'evidence_complete: %s\n' "$evidence_complete"
    printf 'lifecycle_valid: %s\n' "$lifecycle_valid"
    printf 'contract_matches_evidence: %s\n' "$contract_matches_evidence"
    printf 'scope_valid: %s\n' "$scope_valid"
    printf 'steering_valid: %s\n' "$steering_valid"
    printf 'spawn_policy_valid: %s\n' "$spawn_policy_valid"
    printf 'blocking_reasons: %s\n' "$blocking_reasons"
    printf 'END_VALIDATION_CONTRACT\n'
  } > "$validator_report"

  validate_validation_contract "$validator_report" || fail "validator emitted invalid VALIDATION_CONTRACT: $validator_report"
  [[ "$validated" == "true" ]] || fail "deterministic validator rejected certification evidence; see $validator_report"
}

require_trace_health() {
  local session_id="$1"
  local fixture_name="${2:-}"
  local trace_file
  trace_file="$(trace_file_for_session "$session_id")"
  [[ -f "$trace_file" ]] || fail "expected session trace missing: $trace_file"
  grep -q 'session' "$trace_file" || fail "trace lacks session events: $trace_file"
  if [[ "$adapter" == "pi" ]] && trace_has_operational_failures "$trace_file"; then
    fail "live certification trace contains operational failures (agent.error, worker_failed, session error): $trace_file"
  fi
  if [[ "$adapter" == "pi" ]]; then
    local missing_leads worker_spawn_count leaked_contract_count empty_output_count drift_count wrong_fixture_count repo_source_read_count
    missing_leads="$({ missing_required_review_leads "$trace_file" || true; })"
    [[ -z "$missing_leads" ]] || fail "live certification missing required review lead(s): $missing_leads in $trace_file"

    worker_spawn_count="$(jq -r '
      def aid: (.agent_id // .data.agent_id // "");
      select(
        (
          .type == "agent.start" and
          (aid != "") and
          ((aid | test("-lead$")) | not) and
          ((aid | startswith("synth-")) | not) and
          aid != "pi-orchestrator" and
          aid != "echo-orchestrator"
        ) or
        (.event_type == "agent_spawn" and ((.data.agent_role // "") == "worker"))
      )
      | aid // .id // "worker"
    ' "$trace_file" | wc -l | tr -d ' ')"
    [[ "$worker_spawn_count" == "0" ]] || fail "live Phase 1 certification must run lead-only; got $worker_spawn_count worker spawn events in $trace_file"

    leaked_contract_count="$({ non_synthesis_contract_artifacts "$trace_file" || true; } | wc -l | tr -d ' ')"
    [[ "$leaked_contract_count" == "0" ]] || fail "live certification leaked CERTIFICATION_CONTRACT outside synthesis; got $leaked_contract_count non-synthesis artifact(s) under $trace_dir/$session_id/artifacts"

    empty_output_count="$({ unsuperseded_empty_output_artifacts "$trace_file" || true; } | wc -l | tr -d ' ')"
    [[ "$empty_output_count" == "0" ]] || fail "live certification produced unsuperseded empty-output artifacts; got $empty_output_count under $trace_dir/$session_id/artifacts"

    repo_source_read_count="$(jq -r --arg root "$root" --arg workdir "$workdir" 'select(.type == "tool.call") | (.args_preview // "") | select((index($root) != null) and (index($workdir) == null))' "$trace_file" | wc -l | tr -d ' ')"
    [[ "$repo_source_read_count" == "0" ]] || fail "live certification inspected repository source during fixture-only certification; got $repo_source_read_count offending tool calls in $trace_file"

    drift_count="$(jq -r --arg workdir "$workdir" 'select(.type == "tool.call") | (.args_preview // "") | select(test("/mae-cert\\.[^/]+/") and (startswith($workdir) | not))' "$trace_file" | wc -l | tr -d ' ')"
    [[ "$drift_count" == "0" ]] || fail "live certification tool calls escaped current certification workdir; got $drift_count in $trace_file"

    if [[ -n "$fixture_name" ]]; then
      wrong_fixture_count="$(jq -r --arg workdir "$workdir" --arg fixture "$fixture_name" 'select(.type == "tool.call") | (.args_preview // "") | select(startswith($workdir) and (test("/mae-cert\\.[^/]+/(clean|seeded|failing)(/|$)")) and (startswith($workdir + "/" + $fixture) | not))' "$trace_file" | wc -l | tr -d ' ')"
      [[ "$wrong_fixture_count" == "0" ]] || fail "live certification inspected the wrong fixture for $fixture_name; got $wrong_fixture_count offending tool calls in $trace_file"
    fi
  fi
}

run_review() {
  local name="$1"
  local prompt="$2"
  local outfile="$workdir/${name}.out"
  local errfile="$workdir/${name}.err"
  local default_timeout="60"
  [[ "$adapter" == "pi" ]] && default_timeout="150"
  local timeout_secs="${MAE_CERT_TIMEOUT:-$default_timeout}"
  log "running $name review with adapter=$adapter timeout=${timeout_secs}s"
  local exit_code=0
  (
    cd "$root"
    env MAE_CERTIFICATION_MODE=1 MAE_DASHBOARD_URL="$dashboard_url" MAE_TRACE_DIR="$trace_dir" \
      bun "$root/engine/cli.ts" chain swarm-review "$prompt" --adapter "$adapter"
  ) >"$outfile" 2>"$errfile" &
  local review_pid=$!
  timeout "$timeout_secs" bash -c 'while kill -0 "$1" 2>/dev/null; do sleep 0.2; done' _ "$review_pid" || {
    kill "$review_pid" 2>/dev/null || true
    wait "$review_pid" 2>/dev/null || true
    exit_code=124
  }
  if [[ "$exit_code" == 0 ]]; then
    wait "$review_pid" || exit_code=$?
  fi
  if [[ "$exit_code" != 0 ]]; then
    if [[ "$exit_code" == 124 ]]; then
      fail "$name review timed out after ${timeout_secs}s; see $outfile and $errfile"
    fi
    return "$exit_code"
  fi

  local session_id
  session_id="$(extract_session_id "$outfile" "$errfile")"
  if [[ -n "$session_id" ]]; then
    require_trace_health "$session_id" "$name"
    local canonical_report
    canonical_report="$(review_report_path "$session_id" "$outfile")" || fail "canonical live synthesis artifact missing for session $session_id; see $outfile and $errfile"
    if [[ "$adapter" == "pi" ]]; then
      run_deterministic_validator "$session_id" "$name" "$canonical_report"
    fi
    echo "$canonical_report"
  else
    if [[ "$adapter" == "pi" ]]; then
      fail "live review did not expose a session id; see $outfile and $errfile"
    fi
    echo "$outfile"
  fi
}

cleanup() {
  if [[ -n "$workdir" && "$certification_done" == 1 && "${MAE_CERT_KEEP_ARTIFACTS:-0}" != 1 ]]; then
    rm -rf "$workdir"
  elif [[ -n "$workdir" ]]; then
    printf '\n==> preserved certification artifacts: %s\n' "$workdir" >&2
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --live-pi) live_pi=1; shift ;;
      --dashboard-url)
        [[ $# -ge 2 && -n "${2:-}" ]] || { echo "--dashboard-url requires a URL" >&2; usage >&2; exit 1; }
        dashboard_url="$2"
        shift 2
        ;;
      --only)
        [[ $# -ge 2 && "${2:-}" =~ ^(clean|seeded|failing)$ ]] || { echo "--only requires one of: clean, seeded, failing" >&2; usage >&2; exit 1; }
        only_fixture="$2"
        shift 2
        ;;
      -h|--help) usage; exit 0 ;;
      *) echo "unknown arg: $1" >&2; usage >&2; exit 1 ;;
    esac
  done

  if [[ "$live_pi" == 1 ]]; then
    adapter="pi"
  fi
}

main() {
  parse_args "$@"
  require_tool jq
  [[ -f "$root/engine/cli.ts" ]] || fail "repo CLI source missing: $root/engine/cli.ts"
  workdir="$(mktemp -d "${TMPDIR:-/tmp}/mae-cert.XXXXXX")"
  workdir="$(cd "$workdir" && pwd -P)"
  trace_dir="$workdir/traces"
  mkdir -p "$trace_dir"
  trap cleanup EXIT

  log "dashboard health: $dashboard_url"
  curl -fsS "$dashboard_url/api/health" >/dev/null || fail "dashboard health failed"
  spa_status="$(curl -s -o /dev/null -w '%{http_code}' "$dashboard_url/")"
  [[ "$spa_status" == "200" ]] || fail "dashboard SPA HTTP $spa_status"

  mkdir -p "$workdir/clean" "$workdir/seeded" "$workdir/failing"
  cat > "$workdir/clean/app.ts" <<'TS'
export function add(a: number, b: number): number {
  return a + b;
}
TS
  cat > "$workdir/seeded/server.ts" <<'TS'
import { exec } from "node:child_process";

export function lookup(name: string): void {
  exec("nslookup " + name); // seeded command-injection bug: reviewer should flag P0/P1
}
TS
  cat > "$workdir/failing/README.md" <<'MD'
This fixture intentionally lacks the required readiness marker.
MD

  clean_prompt="Certification clean fixture: inspect only $workdir/clean/app.ts. Do not inspect repo source, scripts, traces, other temp fixtures, or previous certification artifacts. Report review findings. Clean fixture should have no P0/P1 blockers. Do not modify files."
  seeded_prompt="Certification seeded fixture: inspect only $workdir/seeded/server.ts. Do not inspect repo source, scripts, traces, other temp fixtures, or previous certification artifacts. Find the seeded command-injection/security bug with file evidence and P0/P1 severity. Do not modify files."
  failing_prompt="Certification failing fixture: inspect only $workdir/failing/README.md. Do not inspect repo source, scripts, traces, clean/seeded fixtures, other temp fixtures, or previous certification artifacts. This file lacks all required certification markers. Your job is to certify the TARGET CODE, not to evaluate whether the test fixture is well-designed. The target code is not certification ready. MANDATORY: your CERTIFICATION_CONTRACT must have verdict: fail and certification_ready: false. Any contract with verdict: pass or certification_ready: true is WRONG for this fixture — it means you are evaluating the fixture's design quality instead of the target code's certification status. Do not propose adding the marker as a fix. Do not modify files."

  if [[ "$only_fixture" == "all" || "$only_fixture" == "clean" ]]; then
    clean_out="$(run_review clean "$clean_prompt")" || fail "clean review command failed; see $workdir/clean.out and $workdir/clean.err"
    validate_certification_contract "$clean_out" clean || fail "clean fixture missing valid certification contract; see $clean_out"
  fi

  if [[ "$only_fixture" == "all" || "$only_fixture" == "seeded" ]]; then
    seeded_out="$(run_review seeded "$seeded_prompt")" || fail "seeded review command failed; see $workdir/seeded.out and $workdir/seeded.err"
    if [[ "$adapter" == "pi" ]]; then
      validate_certification_contract "$seeded_out" seeded || fail "seeded fixture missing valid failing certification contract; see $seeded_out"
      has_seeded_command_injection_evidence "$seeded_out" || fail "seeded fixture did not produce P0/P1 command-injection evidence; see $seeded_out"
    else
      grep -q 'exec("nslookup " + name)' "$workdir/seeded/server.ts" || fail "seeded fixture missing deterministic command-injection seed"
    fi
  fi

  if [[ "$only_fixture" == "all" || "$only_fixture" == "failing" ]]; then
    failing_out="$(run_review failing "$failing_prompt")" || fail "failing review command failed; see $workdir/failing.out and $workdir/failing.err"
    if [[ "$adapter" == "pi" ]]; then
      validate_certification_contract "$failing_out" failing || fail "failing fixture missing valid not-ready certification contract; see $failing_out"
    fi
    if marks_certification_ready "$failing_out"; then
      fail "failing fixture was incorrectly marked certification ready; see $failing_out"
    fi
  fi

  log "trace completeness smoke"
  last_session=""
  for candidate in failing seeded clean; do
    if [[ -f "$workdir/$candidate.out" || -f "$workdir/$candidate.err" ]]; then
      last_session="$(extract_session_id "$workdir/$candidate.out" "$workdir/$candidate.err")"
      [[ -n "$last_session" ]] && break
    fi
  done
  if [[ -n "$last_session" ]]; then
    require_trace_health "$last_session"
    trace_file="$(trace_file_for_session "$last_session")"
  else
    latest_trace="$(find "$trace_dir" -maxdepth 1 -name '*.jsonl' -type f -print0 2>/dev/null | xargs -0 ls -t 2>/dev/null | head -1 || true)"
    [[ -n "$latest_trace" ]] || fail "no trace JSONL files found in isolated trace dir"
    trace_file="$latest_trace"
    grep -q 'session' "$trace_file" || fail "trace lacks session events"
  fi

  certification_done=1
  if [[ "$adapter" == "echo" ]]; then
    log "CERTIFICATION PASS (smoke-only) adapter=$adapter trace=$trace_file"
  else
    log "CERTIFICATION PASS adapter=$adapter trace=$trace_file"
  fi
}

if [[ "${MAE_CERT_SOURCE_ONLY:-0}" != 1 ]]; then
  main "$@"
fi
