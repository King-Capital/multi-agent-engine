# MAE Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env
# Or set these in ~/.mae/config (shell-sourced by the mae CLI)

# ── Dashboard ──────────────────────────────────────────────
MAE_DASHBOARD_URL="http://your-dashboard-host:8400"
DASHBOARD_PORT="8400"
# DASHBOARD_DATA_DIR="./data/sessions"           # Default: ./data/sessions
# CORS_ORIGINS="http://localhost:5173"            # Comma-separated allowed origins

# ── Database ───────────────────────────────────────────────
DATABASE_URL="postgres://mae:changeme@your-db-host:5432/mae?sslmode=disable"

# ── LLM Gateway (LiteLLM, OpenRouter, or any OpenAI-compatible proxy) ──
MAE_LLM_GATEWAY_URL="http://your-llm-proxy:4000"
MAE_LLM_GATEWAY_KEY="sk-your-gateway-key"
# Legacy aliases (still supported):
# LITELLM_URL="http://your-llm-proxy:4000"
# LITELLM_KEY="sk-your-key"
# LITELLM_API_KEY="sk-your-key"

# ── Direct Provider Keys (if not using a gateway) ─────────
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."

# ── Auth ───────────────────────────────────────────────────
# MAE_API_TOKEN="your-dashboard-api-token"        # For authenticated API calls

# ── A2A (Agent-to-Agent) ──────────────────────────────────
# MAE_A2A_URL="http://your-a2a-agent:41271"
# MAE_A2A_TOKEN="your-a2a-bearer-token"
# MAE_A2A_DEFAULT_HOST="your-a2a-agent-host"       # Used by: mae setup a2a --standard
# MAE_A2A_DEFAULT_PORT="41271"

# ── Sandbox Pool (Proxmox LXC containers) ─────────────────
# PVE_API="https://your-proxmox:8006/api2/json"
# PVE_TOKEN="user@pam!tokenid=token-value"
# PVE_NODE="your-node-name"
# MAE_SANDBOX_SUBNET="10.0.0"                    # Subnet for sandbox IPs
# MAE_SANDBOX_HOST_OFFSET="81"                   # First host octet (81 = .81, .82, ...)
# MAE_SANDBOX_GATEWAY="10.0.0.1"                 # Gateway for sandbox network

# ── Misc ──────────────────────────────────────────────────
# MAE_ROOT="/opt/mae"                             # Override engine root directory
# MAE_LOCAL="1"                                   # Use localhost dashboard
# MAE_DEFAULT_ADAPTER="pi"                        # Default adapter: pi, claude-code, codex, echo
