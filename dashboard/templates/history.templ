package templates

import (
	"fmt"
)

type HistoryEntry struct {
	ID          string
	Name        string
	Chain       string
	Status      string
	CreatedAt   string
	CompletedAt string
	TotalCost   float64
	AgentCount  int
	DurationSec float64
}

func statusBadgeClass(status string) string {
	switch status {
	case "completed":
		return "bg-emerald-500/20 text-emerald-400 border-emerald-500/30"
	case "failed":
		return "bg-red-500/20 text-red-400 border-red-500/30"
	case "active":
		return "bg-cyan-500/20 text-cyan-400 border-cyan-500/30"
	case "cancelled":
		return "bg-neutral-500/20 text-neutral-400 border-neutral-500/30"
	default:
		return "bg-neutral-500/20 text-neutral-400 border-neutral-500/30"
	}
}

templ HistoryPage(entries []HistoryEntry) {
	@Layout("Run History") {
		<div class="p-6 max-w-6xl mx-auto" x-data="{ expandedRun: '', selected: [], toggleSelect(id) { const idx = this.selected.indexOf(id); if (idx >= 0) { this.selected.splice(idx, 1); } else if (this.selected.length < 2) { this.selected.push(id); } } }">
			<div class="flex items-center justify-between mb-6">
				<div>
					<h1 class="text-2xl font-bold flex items-center gap-2">
						<i class="ph-bold ph-clock-counter-clockwise text-2xl neon-green"></i>
						Run History
					</h1>
					<p class="text-sm text-neutral-400 mt-1">Past chain runs with cost, duration, and replay</p>
				</div>
				<div class="flex items-center gap-3">
					<!-- Compare Selected button (appears when 2 selected) -->
					<template x-if="selected.length === 2">
						<a 
							:href="'/compare?a=' + selected[0] + '&b=' + selected[1]"
							class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-cyan-500/20 text-cyan-400 border border-cyan-500/30 hover:bg-cyan-500/30 transition-colors text-sm font-medium"
						>
							<i class="ph-bold ph-scales"></i> Compare Selected
						</a>
					</template>
					<template x-if="selected.length === 1">
						<span class="text-xs text-neutral-500">Select 1 more to compare</span>
					</template>
					<a href="/" class="text-sm text-neutral-400 hover:text-neutral-200 flex items-center gap-1">
						<i class="ph-bold ph-arrow-left"></i> Dashboard
					</a>
				</div>
			</div>

			<!-- Stats Summary Bar -->
			<div
				x-data="{ stats: null, loading: true }"
				x-init="fetch('/api/pg/stats').then(r=>r.json()).then(d=>{stats=d;loading=false}).catch(()=>{loading=false})"
				class="mb-6"
			>
				<template x-if="!loading && stats">
					<div class="grid grid-cols-2 md:grid-cols-4 gap-3">
						<div class="border border-neutral-50/5 rounded-lg bg-neutral-50/3 p-4">
							<div class="text-xs text-neutral-500 uppercase tracking-wider mb-1">Total Runs</div>
							<div class="text-2xl font-bold neon-green" x-text="stats.total_sessions.toLocaleString()"></div>
						</div>
						<div class="border border-neutral-50/5 rounded-lg bg-neutral-50/3 p-4">
							<div class="text-xs text-neutral-500 uppercase tracking-wider mb-1">Total Cost</div>
							<div class="text-2xl font-bold neon-green" x-text="'$' + stats.total_cost.toFixed(2)"></div>
						</div>
						<div class="border border-neutral-50/5 rounded-lg bg-neutral-50/3 p-4">
							<div class="text-xs text-neutral-500 uppercase tracking-wider mb-1">Agents Spawned</div>
							<div class="text-2xl font-bold neon-green" x-text="stats.total_agents.toLocaleString()"></div>
						</div>
						<div class="border border-neutral-50/5 rounded-lg bg-neutral-50/3 p-4">
							<div class="text-xs text-neutral-500 uppercase tracking-wider mb-1">Avg Cost / Run</div>
							<div class="text-2xl font-bold neon-green" x-text="stats.total_sessions > 0 ? '$' + (stats.total_cost / stats.total_sessions).toFixed(2) : '$0.00'"></div>
						</div>
					</div>
				</template>
			</div>

			if len(entries) == 0 {
				<div class="text-center text-neutral-500 py-16">
					<i class="ph-bold ph-empty text-4xl mb-3 block"></i>
					<p>No runs recorded yet. Start a chain from the dashboard.</p>
				</div>
			} else {
				<div class="space-y-2">
					for _, e := range entries {
						<div class="border border-neutral-50/5 rounded-lg bg-neutral-50/3 hover:bg-neutral-50/5 transition-colors" :class={ templ.SafeScript(fmt.Sprintf("selected.includes('%s') ? 'ring-1 ring-cyan-500/40' : ''", e.ID)) }>
							<div class="flex items-center justify-between p-4">
								<!-- Compare checkbox -->
								<div 
									class="flex items-center gap-3 min-w-0 cursor-pointer flex-1"
									@click={ templ.SafeScript(fmt.Sprintf("expandedRun = expandedRun === '%s' ? '' : '%s'", e.ID, e.ID)) }
								>
									<label class="flex items-center" @click.stop="">
										<input 
											type="checkbox" 
											class="w-4 h-4 rounded border-neutral-600 bg-neutral-800 text-cyan-500 focus:ring-cyan-500 focus:ring-offset-0 cursor-pointer"
											:checked={ templ.SafeScript(fmt.Sprintf("selected.includes('%s')", e.ID)) }
											:disabled={ templ.SafeScript(fmt.Sprintf("!selected.includes('%s') && selected.length >= 2", e.ID)) }
											@change={ templ.SafeScript(fmt.Sprintf("toggleSelect('%s')", e.ID)) }
										/>
									</label>
									<span class={ "text-xs px-2 py-0.5 rounded border " + statusBadgeClass(e.Status) }>
										{ e.Status }
									</span>
									<span class="font-medium truncate">{ e.Name }</span>
									if e.Chain != "" {
										<span class="text-xs px-1.5 py-0.5 rounded bg-violet-500/20 text-violet-300 border border-violet-500/30">
											{ e.Chain }
										</span>
									}
								</div>
								<div 
									class="flex items-center gap-4 text-sm text-neutral-400 flex-shrink-0 cursor-pointer"
									@click={ templ.SafeScript(fmt.Sprintf("expandedRun = expandedRun === '%s' ? '' : '%s'", e.ID, e.ID)) }
								>
									<span title="Agents">
										<i class="ph-bold ph-robot"></i> { fmt.Sprintf("%d", e.AgentCount) }
									</span>
									<span title="Cost">
										<i class="ph-bold ph-currency-dollar"></i> { fmt.Sprintf("$%.2f", e.TotalCost) }
									</span>
									<span title="Duration">
										<i class="ph-bold ph-timer"></i> { formatDuration(int64(e.DurationSec * 1000)) }
									</span>
									<span class="text-xs">{ e.CreatedAt }</span>
									<i class="ph-bold ph-caret-down transition-transform" :class={ templ.SafeScript(fmt.Sprintf("expandedRun === '%s' ? 'rotate-180' : ''", e.ID)) }></i>
								</div>
							</div>
							<!-- Expandable detail: event replay -->
							<div 
								x-show={ templ.SafeScript(fmt.Sprintf("expandedRun === '%s'", e.ID)) }
								x-transition
								class="border-t border-neutral-50/5 p-4"
							>
								<div 
									x-data="{ events: [], loading: true }"
									x-init={ templ.SafeScript(fmt.Sprintf("fetch('/api/pg/sessions/%s/events').then(r=>r.json()).then(d=>{events=d||[];loading=false}).catch(()=>{loading=false})", e.ID)) }
								>
									<template x-if="loading">
										<p class="text-sm text-neutral-500"><i class="ph-bold ph-spinner animate-spin"></i> Loading events...</p>
									</template>
									<template x-if="!loading && events.length === 0">
										<p class="text-sm text-neutral-500">No events recorded for this run.</p>
									</template>
									<template x-if="!loading && events.length > 0">
										<div class="space-y-1 max-h-96 overflow-y-auto text-xs font-mono">
											<template x-for="ev in events" :key="ev.id">
												<div class="flex gap-3 py-1 border-b border-neutral-50/3">
													<span class="text-neutral-600 w-20 flex-shrink-0" x-text="new Date(ev.created_at).toLocaleTimeString()"></span>
													<span class="w-28 flex-shrink-0" :class="{
														'text-cyan-400': ev.event_type === 'agent_start',
														'text-emerald-400': ev.event_type === 'agent_done',
														'text-amber-400': ev.event_type === 'tool_call',
														'text-red-400': ev.event_type === 'error',
														'text-neutral-400': true
													}" x-text="ev.event_type"></span>
													<span class="text-neutral-500 w-24 flex-shrink-0" x-text="ev.agent_id || '-'"></span>
													<span class="text-neutral-300 truncate" x-text="JSON.stringify(ev.payload || {}).substring(0, 200)"></span>
												</div>
											</template>
										</div>
									</template>
								</div>
							</div>
						</div>
					}
				</div>
			}
		</div>
	}
}
