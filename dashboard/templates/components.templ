package templates

import (
	"fmt"
	"sort"
	"strings"
	"time"
	"mae.local/dashboard/internal/models"
)

func easternTZ() *time.Location {
	loc, err := time.LoadLocation("America/New_York")
	if err != nil {
		return time.UTC
	}
	return loc
}

// --- Session List ---

templ SessionList(sessions []*models.Session) {
	@SessionListItems(sessions)
}

templ SessionListItems(sessions []*models.Session) {
	if len(sessions) == 0 {
		<p class="text-xs text-neutral-500 p-2">No sessions yet.</p>
	}
	for _, sess := range sessions {
			<a
				href={ templ.SafeURL("/session/" + sess.ID) }
				id={ "sess-" + sess.ID }
				class="relative block p-2.5 rounded-md mb-1 hover:bg-neutral-50/5 transition-colors cursor-pointer no-underline text-inherit"
				data-status={ sess.Status }
				x-data="{ ctxOpen: false, ctxX: 0, ctxY: 0 }"
				x-show={ "filters.size === 0 || filters.has('" + sess.Status + "')" }
				x-transition
				@contextmenu.prevent="ctxX = $event.offsetX; ctxY = $event.offsetY; ctxOpen = true; window.__ctxMenuOpen = true"
				@click.away="ctxOpen = false; window.__ctxMenuOpen = false"
			>
				<!-- Session name with chain type badge -->
				<div class="flex items-center gap-1.5 mb-0.5">
					<span class={ "w-2 h-2 rounded-full flex-shrink-0 " + sessionDotClass(sess.Status) }></span>
					<span class="text-sm font-bold truncate">{ sess.Name }</span>
				</div>
				<!-- Chain + platform info -->
				<div class="ml-3.5 mb-0.5 flex items-center gap-1.5">
					if sess.ChainType != "" {
						<span class={ "text-xs px-1.5 py-0.5 rounded " + chainBadgeClass(sess.ChainType) }>
							{ sess.ChainType }
						</span>
					} else if sess.TeamConfig != "" {
						<span class="text-xs px-1 py-0.25 rounded bg-neutral-50/5 text-neutral-400">
							{ sess.TeamConfig }
						</span>
					}
				</div>
				if sess.TaskPrompt != "" {
					<p class="text-xs text-neutral-500 ml-3.5 truncate" title={ sess.TaskPrompt }>
						{ truncateText(sess.TaskPrompt, 60) }
					</p>
				}
				<!-- Stats row -->
				<div class="flex items-center gap-2 text-xs text-neutral-600 mt-1 ml-3.5">
					<span title="Agents">
						<i class="ph-bold ph-users"></i>
						{ fmt.Sprintf("%d", len(sess.Agents)) }
					</span>
					<span title="Cost">
						<i class="ph-bold ph-coins"></i>
						{ fmt.Sprintf("$%.2f", sess.TotalCost) }
					</span>
					<span title="Duration">
						<i class="ph-bold ph-timer"></i>
						{ formatDuration(sess.ElapsedMs) }
					</span>
					<span class="text-neutral-500" title={ sess.StartedAt.In(easternTZ()).Format("Jan 2, 2006 3:04:05 PM") }>
						{ sess.StartedAt.In(easternTZ()).Format("3:04 PM") }
					</span>
					<span class="text-neutral-700 text-[10px]" title={ sess.ID }>
						{ sess.ID[:6] }
					</span>
				</div>
				<!-- Right-click context menu -->
				<div
					x-show="ctxOpen"
					x-transition
					@click.stop=""
					class="absolute z-50 rounded-md shadow-xl border border-neutral-50/10 py-1 min-w-36"
					style="background: rgba(15, 20, 30, 0.95); backdrop-filter: blur(12px);"
					:style="'left:' + ctxX + 'px; top:' + ctxY + 'px'"
				>
					<div class="px-2 py-1 text-xs text-neutral-500 border-b border-neutral-50/5">
						{ sess.ID[:8] } · { sess.Status }
					</div>
					if sess.Status != "completed" {
						<button
							class="w-full text-left px-2 py-1.5 text-xs text-blue-400 hover:bg-blue-500/10 transition-colors flex items-center gap-1.5"
							hx-patch={ fmt.Sprintf("/api/sessions/%s/status", sess.ID) }
							hx-vals='{"status":"completed"}'
							hx-target="#session-list"
							hx-swap="innerHTML"
							@click="ctxOpen = false"
						>
							<i class="ph-bold ph-check-circle"></i> Mark Done
						</button>
					}
					if sess.Status != "error" {
						<button
							class="w-full text-left px-2 py-1.5 text-xs text-red-400 hover:bg-red-500/10 transition-colors flex items-center gap-1.5"
							hx-patch={ fmt.Sprintf("/api/sessions/%s/status", sess.ID) }
							hx-vals='{"status":"error"}'
							hx-target="#session-list"
							hx-swap="innerHTML"
							@click="ctxOpen = false"
						>
							<i class="ph-bold ph-x-circle"></i> Mark Error
						</button>
					}
					<div class="border-t border-neutral-50/5 mt-0.5 pt-0.5">
						<button
							class="w-full text-left px-2 py-1.5 text-xs text-red-500 hover:bg-red-500/10 transition-colors flex items-center gap-1.5"
							hx-delete={ fmt.Sprintf("/api/sessions/%s", sess.ID) }
							hx-target="#session-list"
							hx-swap="innerHTML"
							hx-confirm="Delete this session permanently?"
							@click="ctxOpen = false"
						>
							<i class="ph-bold ph-trash"></i> Delete
						</button>
					</div>
				</div>
			</a>
	}
}

// --- Agent Tree ---

templ AgentTree(sess *models.Session) {
	if len(sess.Agents) == 0 {
		<p class="text-xs text-neutral-500">Waiting for agents to spawn...</p>
	} else {
		for _, agent := range getRootAgents(sess) {
			@AgentNode(agent, sess, 0)
		}
	}
}

templ AgentNode(agent *models.Agent, sess *models.Session, depth int) {
	<div class={ agentNodeClass(depth) }>
		<div class="flex items-center gap-1.5 py-1">
			<!-- Status emoji indicator -->
			<span class="text-sm leading-none" title={ string(agent.Status) }>
				{ statusEmoji(agent.Status) }
			</span>
			<!-- Role icon -->
			<span class={ "text-xs font-bold " + roleIconColor(agent) }>
				{ roleIcon(agent.Role) }
			</span>
			<!-- Name -->
			<span class="text-xs font-bold truncate" style={ "color:" + agentColor(agent) }>
				{ qualifiedName(agent) }
			</span>
		</div>
		<div class="flex items-center gap-2 text-xs text-neutral-500 ml-5">
			<span title="Cost">
				<i class="ph-bold ph-coins"></i>
				{ fmt.Sprintf("$%.3f", agent.CostUSD) }
			</span>
			<span title="Context">
				<i class="ph-bold ph-brain"></i>
				{ formatTokens(agent.ContextTokens) }
			</span>
			if agent.Model != "" {
				<span class="text-neutral-600 truncate max-w-20" title={ agent.Model }>
					{ shortModel(agent.Model) }
				</span>
			}
		</div>
		<!-- Children -->
		for _, child := range getChildren(sess, agent.ID) {
			@AgentNode(child, sess, depth+1)
		}
	</div>
}

// --- Conversation Stream ---

templ ConversationStream(sess *models.Session) {
	<div x-data="{ showTools: false }">
		for _, evt := range sess.Events {
			switch evt.EventType {
				case models.EventMessage:
					@MessageBubble(evt, sess)
				case models.EventDomainBlock:
					@DomainBlockEntry(evt)
				case models.EventSelfHeal:
					@SelfHealEntry(evt, sess)
				case models.EventError:
					@ErrorEntry(evt, sess)
			}
		}
		// ALL tool calls -- collapsed at bottom
		if hasToolCalls(sess) {
			<div class="mt-3 border-t border-neutral-800 pt-2">
				<button class="text-xs text-neutral-600 hover:text-neutral-400 transition-colors flex items-center gap-1"
					@click="showTools = !showTools">
					<span x-text="showTools ? '▼' : '▶'"></span>
					<span>Tool calls ({ toolCallCount(sess) })</span>
				</button>
				<div x-show="showTools" x-transition class="mt-1">
					for _, evt := range sess.Events {
						if evt.EventType == models.EventToolCall {
							@ToolCallEntry(evt, sess)
						}
					}
				</div>
			</div>
		}
		if sess.Status == "active" || sess.Status == "waiting" {
			<div class="mt-4 border-t border-neutral-800 pt-3" x-data={ "{ msg: \"\" , sid: \"" + sess.ID + "\" }" }>
				<form class="flex gap-2"
					@submit.prevent="
						if (!msg.trim()) return;
						fetch('/api/sessions/' + encodeURIComponent(sid) + '/message', {
							method: 'POST',
							headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
							body: 'content=' + encodeURIComponent(msg)
						});
						msg = '';
					"
				>
					<input type="text" x-model="msg"
						placeholder="Steer the orchestrator..."
						class="flex-1 bg-neutral-900 border border-neutral-700 rounded-md px-3 py-1.5 text-sm text-neutral-200 placeholder-neutral-600 focus:outline-none focus:border-cyan-500/50"
					/>
					<button type="submit"
						class="px-3 py-1.5 bg-cyan-600/30 hover:bg-cyan-600/50 text-cyan-300 text-sm rounded-md transition-colors"
					>Send</button>
				</form>
			</div>
		}
	</div>
}


templ MessageBubble(evt models.Event, sess *models.Session) {
	{{ agent := sess.Agents[evt.AgentID] }}
	{{ agentName := evt.AgentID }}
	{{ color := "#94a3b8" }}
	if agent != nil {
		{{ agentName = qualifiedName(agent) }}
		{{ color = agentColor(agent) }}
	}
	<div class="mb-3">
		<div class="flex items-center gap-2 mb-0.5">
			<span class="text-xs font-bold" style={ "color:" + color }>
				{ roleLabel(agent) }
			</span>
			<span class="text-xs font-bold" style={ "color:" + color }>
				{ agentName }
			</span>
			<span class="text-xs text-neutral-600">
				{ evt.Timestamp.In(easternTZ()).Format("3:04:05 PM") }
			</span>
		</div>
		<div class="glass rounded-md p-2.5 text-sm text-neutral-300 ml-4 msg-md" data-md={ evt.Data.Content }>
		</div>
	</div>
}

templ ToolCallEntry(evt models.Event, sess *models.Session) {
	{{ agent := sess.Agents[evt.AgentID] }}
	{{ color := "#94a3b8" }}
	if agent != nil {
		{{ color = agentColor(agent) }}
	}
	<div class="mb-1 ml-4 text-xs tool-entry" x-data="{ open: false }">
		<!-- Collapsed header (always visible) -->
		<button
			class="flex items-center gap-1.5 text-neutral-500 hover:text-neutral-300 transition-colors w-full text-left"
			@click="open = !open"
		>
			<span class="text-neutral-600 w-3 flex-shrink-0" x-text="open ? '▼' : '▶'"></span>
			<span class={ toolStatusIcon(evt.Data.ToolStatus) }></span>
			<span style={ "color:" + color } class="font-medium">
				if agent != nil {
					{ qualifiedName(agent) }
				} else {
					{ evt.AgentID }
				}
			</span>
			<span class="text-neutral-400">{ evt.Data.Tool }</span>
			if evt.Data.FilePath != "" {
				<span class="text-neutral-500 truncate max-w-xs" title={ evt.Data.FilePath }>{ evt.Data.FilePath }</span>
			}
			if evt.Timestamp.Unix() > 0 {
				<span class="text-neutral-700 ml-auto flex-shrink-0">{ evt.Timestamp.In(easternTZ()).Format("3:04:05 PM") }</span>
			}
		</button>
		<!-- Expanded detail -->
		<div x-show="open" x-transition class="mt-1 ml-4 space-y-1">
			if evt.Data.ToolArgs != "" {
				<div class="glass rounded p-1.5">
					<p class="text-neutral-600 mb-0.5 font-bold">args</p>
					<pre class="text-neutral-400 whitespace-pre-wrap break-all text-xs max-h-32 overflow-y-auto">{ evt.Data.ToolArgs }</pre>
				</div>
			}
			if evt.Data.ToolResult != "" {
				<div class="glass rounded p-1.5">
					<p class="text-neutral-600 mb-0.5 font-bold">result</p>
					<pre class="text-neutral-400 whitespace-pre-wrap break-all text-xs max-h-32 overflow-y-auto">{ evt.Data.ToolResult }</pre>
				</div>
			}
		</div>
	</div>
}

templ DomainBlockEntry(evt models.Event) {
	<div class="mb-2 ml-4 glass rounded-md p-2 border-l-2 border-red-500/50">
		<div class="flex items-center gap-1.5 text-xs">
			<i class="ph-bold ph-x-circle text-red-400"></i>
			<span class="text-red-400 font-bold">Domain Block</span>
		</div>
		<p class="text-xs text-neutral-400 mt-0.5">
			{ evt.Data.BlockedAction } on { evt.Data.BlockedPath } -- { evt.Data.BlockReason }
		</p>
	</div>
}

templ SelfHealEntry(evt models.Event, sess *models.Session) {
	<div class="mb-2 ml-4 glass rounded-md p-2 border-l-2 border-yellow-500/50">
		<div class="flex items-center gap-1.5 text-xs">
			<i class="ph-bold ph-wrench neon-yellow"></i>
			<span class="neon-yellow font-bold">Self-Heal</span>
		</div>
		<p class="text-xs text-neutral-400 mt-0.5">
			Worker { evt.Data.FailedWorker } failed. Lead taking over: { evt.Data.HealAction }
		</p>
	</div>
}

templ ErrorEntry(evt models.Event, sess *models.Session) {
	<div class="mb-2 ml-4 glass rounded-md p-2 border-l-2 border-red-500/50">
		<div class="flex items-center gap-1.5 text-xs">
			<i class="ph-bold ph-warning-circle text-red-400"></i>
			<span class="text-red-400 font-bold">Error</span>
			<span class="text-neutral-500">{ evt.AgentID }</span>
		</div>
		<p class="text-xs text-red-300 mt-0.5">{ evt.Data.ErrorMsg }</p>
	</div>
}

// --- TillDone Panel ---

templ TillDonePanel(td *models.TillDoneState) {
	<div>
		<div class="flex items-center justify-between mb-2">
			<span class="text-xs font-bold truncate">{ td.Title }</span>
			<span class="text-xs neon-green">
				{ fmt.Sprintf("[%d/%d]", td.Completed, td.Total) }
			</span>
		</div>
		<!-- Progress bar -->
		<div class="w-full bg-neutral-50/5 rounded-full h-1.5 mb-3">
			<div
				class="bg-green-500 h-1.5 rounded-full transition-all duration-500"
				style={ fmt.Sprintf("width: %d%%", progressPct(td.Completed, td.Total)) }
			></div>
		</div>
		for _, item := range td.Items {
			<div class="flex items-start gap-2 py-1 text-xs">
				if item.Completed {
					<i class="ph-bold ph-check-circle text-green-400 mt-0.5"></i>
				} else if item.Active {
					<i class="ph-bold ph-circle-notch text-yellow-400 mt-0.5 pulse"></i>
				} else {
					<i class="ph-bold ph-circle text-neutral-600 mt-0.5"></i>
				}
				<span class={ tillDoneItemClass(item) }>
					{ item.Description }
				</span>
			</div>
		}
	</div>
}

// --- Cost Tracker ---

templ CostTracker(sess *models.Session) {
	<div>
		<div class="flex items-center justify-between mb-2">
			<span class="text-xs font-bold text-neutral-400">Cost Tree</span>
			<span class="text-sm font-bold neon-green">
				{ fmt.Sprintf("$%.2f", sess.TotalCost) }
			</span>
		</div>
		<!-- Per-agent cost tree -->
		<div class="text-xs font-mono mb-2">
			for i, root := range getRootAgents(sess) {
				{{ isLastRoot := i == len(getRootAgents(sess))-1 }}
				@CostTreeNode(root, sess, "", isLastRoot)
			}
		</div>
		<!-- Totals footer -->
		<div class="border-t border-neutral-50/5 pt-1.5 mt-1.5 flex items-center justify-between text-xs text-neutral-500">
			<span>{ fmt.Sprintf("%d agents", len(sess.Agents)) }</span>
			<span>{ formatTokens(sess.TotalTokens) } tok</span>
		</div>
	</div>
}

templ CostTreeNode(agent *models.Agent, sess *models.Session, prefix string, isLast bool) {
	{{ children := getChildren(sess, agent.ID) }}
	{{ connector := "├── " }}
	if isLast {
		{{ connector = "└── " }}
	}
	<div class="text-neutral-400 leading-5">
		<span class="text-neutral-700">{ prefix }{ connector }</span>
		<span style={ "color:" + agentColor(agent) }>{ agent.Name }</span>
		<span class="text-neutral-500"> { fmt.Sprintf("$%.2f", agent.CostUSD) }</span>
		if agent.Model != "" {
			<span class="text-neutral-700"> { shortModel(agent.Model) }</span>
		}
	</div>
	{{ childPrefix := prefix + "│   " }}
	if isLast {
		{{ childPrefix = prefix + "    " }}
	}
	for ci, child := range children {
		{{ isLastChild := ci == len(children)-1 }}
		@CostTreeNode(child, sess, childPrefix, isLastChild)
	}
}

// --- Helper functions ---

func sessionDotClass(status string) string {
	switch status {
	case "active":
		return "bg-green-400 pulse"
	case "waiting":
		return "bg-yellow-400 pulse"
	case "paused":
		return "bg-amber-400"
	case "completed":
		return "bg-blue-400"
	case "error":
		return "bg-red-400"
	default:
		return "bg-neutral-500"
	}
}

func statusDotClass(status models.AgentStatus) string {
	switch status {
	case models.StatusRunning:
		return "bg-orange-400 pulse"
	case models.StatusDone:
		return "bg-green-400"
	case models.StatusError:
		return "bg-red-500"
	case models.StatusBlocked:
		return "bg-yellow-400"
	default:
		return "bg-neutral-500"
	}
}

func statusEmoji(status models.AgentStatus) string {
	switch status {
	case models.StatusRunning:
		return "🟠"
	case models.StatusDone:
		return "🟢"
	case models.StatusError:
		return "🔴"
	case models.StatusBlocked:
		return "🟡"
	default:
		return "⚪"
	}
}

func roleIcon(role models.AgentRole) string {
	switch role {
	case models.RoleOrchestrator:
		return "O"
	case models.RoleLead:
		return "L"
	case models.RoleWorker:
		return "W"
	default:
		return "?"
	}
}

func roleLabel(agent *models.Agent) string {
	if agent == nil {
		return ""
	}
	switch agent.Role {
	case models.RoleOrchestrator:
		return "O"
	case models.RoleLead:
		return "L"
	case models.RoleWorker:
		return "W"
	default:
		return ""
	}
}

func roleIconColor(agent *models.Agent) string {
	if agent.TeamColor != "" {
		return ""
	}
	switch agent.Role {
	case models.RoleOrchestrator:
		return "neon-green"
	case models.RoleLead:
		return "neon-yellow"
	default:
		return "text-neutral-400"
	}
}

func agentColor(agent *models.Agent) string {
	if agent == nil {
		return "#94a3b8"
	}
	if agent.TeamColor != "" {
		return agent.TeamColor
	}
	switch agent.Role {
	case models.RoleOrchestrator:
		return "#36f9f6"
	case models.RoleLead:
		return "#ffd93d"
	default:
		return "#94a3b8"
	}
}

func agentNodeClass(depth int) string {
	if depth == 0 {
		return "mb-2"
	}
	return "agent-line mb-1"
}

func formatTokens(tokens int64) string {
	if tokens >= 1_000_000 {
		return fmt.Sprintf("%.1fM", float64(tokens)/1_000_000)
	}
	if tokens >= 1_000 {
		return fmt.Sprintf("%dK", tokens/1_000)
	}
	return fmt.Sprintf("%d", tokens)
}

func shortModel(model string) string {
	parts := strings.Split(model, "/")
	m := parts[len(parts)-1]
	m = strings.TrimSuffix(m, "-nocache")
	if len(m) > 15 {
		return m[:15]
	}
	return m
}

func qualifiedName(agent *models.Agent) string {
	if agent == nil {
		return "unknown"
	}
	name := agent.Name
	if agent.TeamName != "" && agent.TeamName != "Orchestration" {
		name = agent.TeamName + ": " + name
	}
	if agent.Model != "" {
		name += " (" + shortModel(agent.Model) + ")"
	}
	return name
}

func toolStatusIcon(status string) string {
	switch status {
	case "success":
		return "ph-bold ph-check text-green-500"
	case "error":
		return "ph-bold ph-x text-red-500"
	case "blocked":
		return "ph-bold ph-x-circle text-red-400"
	default:
		return "ph-bold ph-dots-three text-neutral-500"
	}
}

func tillDoneItemClass(item models.TillDoneItem) string {
	if item.Completed {
		return "text-neutral-500 line-through"
	}
	if item.Active {
		return "text-neutral-200"
	}
	return "text-neutral-400"
}

func progressPct(completed, total int) int {
	if total == 0 {
		return 0
	}
	return (completed * 100) / total
}

func truncateText(s string, maxLen int) string {
	if len(s) <= maxLen {
		return s
	}
	return s[:maxLen-3] + "..."
}

func getRootAgents(sess *models.Session) []*models.Agent {
	var roots []*models.Agent
	for _, a := range sess.Agents {
		if a.ParentID == "" {
			roots = append(roots, a)
		}
	}
	sort.Slice(roots, func(i, j int) bool {
		return roots[i].StartedAt.Before(roots[j].StartedAt)
	})
	return roots
}

func getChildren(sess *models.Session, parentID string) []*models.Agent {
	var children []*models.Agent
	for _, a := range sess.Agents {
		if a.ParentID == parentID {
			children = append(children, a)
		}
	}
	sort.Slice(children, func(i, j int) bool {
		return children[i].StartedAt.Before(children[j].StartedAt)
	})
	return children
}


func isLeadOrOrch(evt models.Event, sess *models.Session) bool {
	if evt.AgentID == "orch-1" || evt.AgentID == "orchestrator" {
		return true
	}
	agent := sess.Agents[evt.AgentID]
	if agent == nil {
		return true // unknown agents shown by default
	}
	return agent.Role == models.RoleOrchestrator || agent.Role == models.RoleLead
}

func hasToolCalls(sess *models.Session) bool {
	for _, evt := range sess.Events {
		if evt.EventType == models.EventToolCall {
			return true
		}
	}
	return false
}

func toolCallCount(sess *models.Session) string {
	count := 0
	for _, evt := range sess.Events {
		if evt.EventType == models.EventToolCall {
			count++
		}
	}
	return fmt.Sprintf("%d", count)
}

func hasWorkerToolCalls(sess *models.Session) bool {
	for _, evt := range sess.Events {
		if evt.EventType == models.EventToolCall {
			agent := sess.Agents[evt.AgentID]
			if agent != nil && agent.Role == models.RoleWorker {
				return true
			}
		}
	}
	return false
}

func workerToolCallCount(sess *models.Session) string {
	count := 0
	for _, evt := range sess.Events {
		if evt.EventType == models.EventToolCall {
			agent := sess.Agents[evt.AgentID]
			if agent != nil && agent.Role == models.RoleWorker {
				count++
			}
		}
	}
	return fmt.Sprintf("%d", count)
}

func chainBadgeClass(chain string) string {
	switch chain {
	case "review-only":
		return "bg-blue-500/20 text-blue-400"
	case "plan-build-review":
		return "bg-green-500/20 text-green-400"
	case "build-verify":
		return "bg-cyan-500/20 text-cyan-400"
	case "swarm-review", "red-blue":
		return "bg-red-500/20 text-red-400"
	case "full-sdlc":
		return "bg-purple-500/20 text-purple-400"
	case "scout-then-plan":
		return "bg-yellow-500/20 text-yellow-400"
	default:
		return "bg-neutral-50/10 text-neutral-400"
	}
}
// --- Agent Graph Visualization ---

// graphNode holds layout info for rendering an agent in the SVG graph.
type graphNode struct {
	Agent *models.Agent
	X     int
	Y     int
	Level int // 0=orchestrator, 1=lead, 2=worker
}

// graphEdge connects two nodes.
type graphEdge struct {
	FromX, FromY int
	ToX, ToY     int
}

// buildGraphLayout computes node positions for the agent hierarchy.
func buildGraphLayout(sess *models.Session) ([]graphNode, []graphEdge) {
	var nodes []graphNode
	var edges []graphEdge

	// Collect agents by role/level
	var orchestrators []*models.Agent
	var leads []*models.Agent
	var workers []*models.Agent

	for _, a := range sess.Agents {
		switch a.Role {
		case models.RoleOrchestrator:
			orchestrators = append(orchestrators, a)
		case models.RoleLead:
			leads = append(leads, a)
		case models.RoleWorker:
			workers = append(workers, a)
		}
	}

	// Sort each group by start time for stable layout
	sort.Slice(orchestrators, func(i, j int) bool { return orchestrators[i].StartedAt.Before(orchestrators[j].StartedAt) })
	sort.Slice(leads, func(i, j int) bool { return leads[i].StartedAt.Before(leads[j].StartedAt) })
	sort.Slice(workers, func(i, j int) bool { return workers[i].StartedAt.Before(workers[j].StartedAt) })

	// Node dimensions
	nodeW := 180
	nodeH := 50
	hGap := 40
	vGap := 80

	// Position index maps
	posMap := make(map[string]graphNode)

	// Place orchestrators (level 0)
	totalOrchW := len(orchestrators)*nodeW + (len(orchestrators)-1)*hGap
	orchStartX := 0
	if totalOrchW > 0 {
		orchStartX = -totalOrchW / 2
	}
	for i, a := range orchestrators {
		x := orchStartX + i*(nodeW+hGap) + nodeW/2
		y := nodeH / 2
		n := graphNode{Agent: a, X: x, Y: y, Level: 0}
		nodes = append(nodes, n)
		posMap[a.ID] = n
	}

	// Place leads (level 1)
	totalLeadW := len(leads)*nodeW + (len(leads)-1)*hGap
	leadStartX := 0
	if totalLeadW > 0 {
		leadStartX = -totalLeadW / 2
	}
	for i, a := range leads {
		x := leadStartX + i*(nodeW+hGap) + nodeW/2
		y := nodeH/2 + nodeH + vGap
		n := graphNode{Agent: a, X: x, Y: y, Level: 1}
		nodes = append(nodes, n)
		posMap[a.ID] = n

		// Edge from parent (orchestrator) to lead
		if parent, ok := posMap[a.ParentID]; ok {
			edges = append(edges, graphEdge{
				FromX: parent.X, FromY: parent.Y + nodeH/2,
				ToX: x, ToY: y - nodeH/2,
			})
		}
	}

	// Group workers by parent lead
	workersByLead := make(map[string][]*models.Agent)
	var orphanWorkers []*models.Agent
	for _, w := range workers {
		if _, ok := posMap[w.ParentID]; ok {
			workersByLead[w.ParentID] = append(workersByLead[w.ParentID], w)
		} else {
			orphanWorkers = append(orphanWorkers, w)
		}
	}

	// Place workers under their leads (level 2)
	workerY := nodeH/2 + 2*(nodeH+vGap)
	allWorkers := make([]*models.Agent, 0)

	// Interleave: place workers grouped under leads, centered on lead X
	for _, lead := range leads {
		wList := workersByLead[lead.ID]
		if len(wList) == 0 {
			continue
		}
		allWorkers = append(allWorkers, wList...)
	}
	allWorkers = append(allWorkers, orphanWorkers...)

	totalWorkerW := len(allWorkers)*nodeW + (len(allWorkers)-1)*hGap
	workerStartX := 0
	if totalWorkerW > 0 {
		workerStartX = -totalWorkerW / 2
	}

	workerIdx := 0
	for _, w := range allWorkers {
		x := workerStartX + workerIdx*(nodeW+hGap) + nodeW/2
		n := graphNode{Agent: w, X: x, Y: workerY, Level: 2}
		nodes = append(nodes, n)
		posMap[w.ID] = n
		workerIdx++

		// Edge from parent to worker
		if parent, ok := posMap[w.ParentID]; ok {
			edges = append(edges, graphEdge{
				FromX: parent.X, FromY: parent.Y + nodeH/2,
				ToX: x, ToY: workerY - nodeH/2,
			})
		}
	}

	// Normalize positions so min X is at a padding offset
	if len(nodes) > 0 {
		minX := nodes[0].X - nodeW/2
		for _, n := range nodes[1:] {
			if n.X-nodeW/2 < minX {
				minX = n.X - nodeW/2
			}
		}
		offsetX := -minX + 20 // 20px left padding
		for i := range nodes {
			nodes[i].X += offsetX
		}
		for i := range edges {
			edges[i].FromX += offsetX
			edges[i].ToX += offsetX
		}
	}

	return nodes, edges
}

func graphViewBox(nodes []graphNode) string {
	if len(nodes) == 0 {
		return "0 0 400 200"
	}
	nodeW := 180
	nodeH := 50
	maxX := 0
	maxY := 0
	for _, n := range nodes {
		right := n.X + nodeW/2 + 20
		bottom := n.Y + nodeH/2 + 20
		if right > maxX {
			maxX = right
		}
		if bottom > maxY {
			maxY = bottom
		}
	}
	return fmt.Sprintf("0 0 %d %d", maxX, maxY)
}

func graphNodeFill(status models.AgentStatus) string {
	switch status {
	case models.StatusRunning:
		return "#0e7490" // cyan-700
	case models.StatusDone:
		return "#166534" // green-800
	case models.StatusError:
		return "#991b1b" // red-800
	case models.StatusBlocked:
		return "#854d0e" // yellow-800
	default:
		return "#374151" // gray-700
	}
}

func graphNodeStroke(status models.AgentStatus) string {
	switch status {
	case models.StatusRunning:
		return "#22d3ee" // cyan-400
	case models.StatusDone:
		return "#4ade80" // green-400
	case models.StatusError:
		return "#f87171" // red-400
	case models.StatusBlocked:
		return "#facc15" // yellow-400
	default:
		return "#6b7280" // gray-500
	}
}

func graphRoleLabel(role models.AgentRole) string {
	switch role {
	case models.RoleOrchestrator:
		return "ORCH"
	case models.RoleLead:
		return "LEAD"
	case models.RoleWorker:
		return "WORK"
	default:
		return "?"
	}
}

func isRunning(status models.AgentStatus) bool {
	return status == models.StatusRunning
}

templ AgentGraph(sess *models.Session) {
	if len(sess.Agents) == 0 {
		<p class="text-xs text-neutral-500">No agents to graph.</p>
	} else {
		{{ nodes, edges := buildGraphLayout(sess) }}
		{{ vb := graphViewBox(nodes) }}
		<svg viewBox={ vb } xmlns="http://www.w3.org/2000/svg" class="w-full" style="min-height: 200px; max-height: 500px;">
			<defs>
				<style>
					@keyframes graphPulse {
						0%, 100% { opacity: 1; }
						50% { opacity: 0.5; }
					}
					.graph-pulse {
						animation: graphPulse 2s ease-in-out infinite;
					}
				</style>
				<!-- Arrow marker for edges -->
				<marker id="arrowhead" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
					<polygon points="0 0, 8 3, 0 6" fill="#4b5563"/>
				</marker>
			</defs>
			<!-- Edges -->
			for _, e := range edges {
				<line
					x1={ fmt.Sprintf("%d", e.FromX) }
					y1={ fmt.Sprintf("%d", e.FromY) }
					x2={ fmt.Sprintf("%d", e.ToX) }
					y2={ fmt.Sprintf("%d", e.ToY) }
					stroke="#4b5563"
					stroke-width="2"
					marker-end="url(#arrowhead)"
				/>
			}
			<!-- Nodes -->
			for _, n := range nodes {
				<g
					if isRunning(n.Agent.Status) {
						class="graph-pulse"
					}
				>
					<rect
						x={ fmt.Sprintf("%d", n.X-90) }
						y={ fmt.Sprintf("%d", n.Y-25) }
						width="180"
						height="50"
						rx="8"
						ry="8"
						fill={ graphNodeFill(n.Agent.Status) }
						stroke={ graphNodeStroke(n.Agent.Status) }
						stroke-width="2"
					/>
					<!-- Role badge -->
					<text
						x={ fmt.Sprintf("%d", n.X) }
						y={ fmt.Sprintf("%d", n.Y-6) }
						text-anchor="middle"
						fill={ graphNodeStroke(n.Agent.Status) }
						font-size="10"
						font-family="monospace"
						font-weight="bold"
					>
						{ graphRoleLabel(n.Agent.Role) }
					</text>
					<!-- Agent name -->
					<text
						x={ fmt.Sprintf("%d", n.X) }
						y={ fmt.Sprintf("%d", n.Y+12) }
						text-anchor="middle"
						fill="#e5e7eb"
						font-size="11"
						font-family="system-ui, sans-serif"
					>
						{ truncateText(n.Agent.Name, 22) }
					</text>
				</g>
			}
		</svg>
	}
}

// --- Session Diff (Files Touched) ---

// fileTypeIcon returns a Phosphor icon class and color for a file extension.
func fileTypeIcon(path string) (string, string) {
	ext := ""
	for i := len(path) - 1; i >= 0; i-- {
		if path[i] == '.' {
			ext = path[i:]
			break
		}
		if path[i] == '/' {
			break
		}
	}
	switch ext {
	case ".ts", ".tsx":
		return "ph-bold ph-file-ts", "text-blue-400"
	case ".js", ".jsx":
		return "ph-bold ph-file-js", "text-yellow-400"
	case ".go":
		return "ph-bold ph-file-code", "text-cyan-400"
	case ".md", ".mdx":
		return "ph-bold ph-file-text", "text-neutral-400"
	case ".json":
		return "ph-bold ph-file-code", "text-green-400"
	case ".yaml", ".yml":
		return "ph-bold ph-file-code", "text-pink-400"
	case ".py":
		return "ph-bold ph-file-py", "text-yellow-300"
	case ".css", ".scss":
		return "ph-bold ph-file-css", "text-purple-400"
	case ".html", ".templ":
		return "ph-bold ph-file-html", "text-orange-400"
	case ".sql":
		return "ph-bold ph-database", "text-emerald-400"
	case ".sh", ".bash":
		return "ph-bold ph-terminal", "text-green-300"
	case ".toml":
		return "ph-bold ph-file-code", "text-amber-400"
	case ".env":
		return "ph-bold ph-lock-key", "text-red-300"
	default:
		return "ph-bold ph-file", "text-neutral-500"
	}
}

// shortFilePath returns just the filename from a path for display.
func shortFilePath(path string) string {
	for i := len(path) - 1; i >= 0; i-- {
		if path[i] == '/' {
			return path[i+1:]
		}
	}
	return path
}

// fileDir returns the directory portion of a path, or empty string.
func fileDir(path string) string {
	for i := len(path) - 1; i >= 0; i-- {
		if path[i] == '/' {
			return path[:i]
		}
	}
	return ""
}

templ SessionDiff(sessionID string) {
	<div x-data={ `{ open: false, files: [], count: 0, loaded: false, loading: false,
		load() {
			if (this.loaded || this.loading) return;
			this.loading = true;
			fetch('/api/pg/sessions/' + encodeURIComponent('` + sessionID + `') + '/diff')
				.then(r => r.json())
				.then(data => {
					this.files = data.files || [];
					this.count = data.count || 0;
					this.loaded = true;
					this.loading = false;
				})
				.catch(() => { this.loading = false; });
		}
	}` }>
		<button
			class="flex items-center gap-2 text-xs text-neutral-500 hover:text-neutral-300 transition-colors w-full text-left"
			@click="open = !open; if (open) load()"
		>
			<span x-text="open ? '▼' : '▶'" class="w-3 flex-shrink-0"></span>
			<i class="ph-bold ph-git-diff"></i>
			<span>Files Modified</span>
			<span
				x-show="loaded"
				x-text="count"
				class="px-1.5 py-0.5 rounded-full bg-cyan-500/20 text-cyan-400 text-xs font-bold"
			></span>
			<span x-show="loading" class="text-neutral-600">loading...</span>
		</button>
		<div x-show="open" x-transition class="mt-2 ml-5 space-y-0.5">
			<template x-if="loaded && files.length === 0">
				<p class="text-xs text-neutral-600 italic">No file modifications detected.</p>
			</template>
			<template x-for="file in files" :key="file">
				<div class="flex items-center gap-2 text-xs py-0.5 group">
					<i :class="fileIcon(file)" class="flex-shrink-0"></i>
					<span class="text-neutral-400 truncate" :title="file" x-text="file"></span>
				</div>
			</template>
		</div>
		<!-- Alpine helper for file icons -->
		<script>
			function fileIcon(path) {
				const ext = path.includes('.') ? path.slice(path.lastIndexOf('.')) : '';
				const map = {
					'.ts': 'ph-bold ph-file-ts text-blue-400',
					'.tsx': 'ph-bold ph-file-ts text-blue-400',
					'.js': 'ph-bold ph-file-js text-yellow-400',
					'.jsx': 'ph-bold ph-file-js text-yellow-400',
					'.go': 'ph-bold ph-file-code text-cyan-400',
					'.md': 'ph-bold ph-file-text text-neutral-400',
					'.mdx': 'ph-bold ph-file-text text-neutral-400',
					'.json': 'ph-bold ph-file-code text-green-400',
					'.yaml': 'ph-bold ph-file-code text-pink-400',
					'.yml': 'ph-bold ph-file-code text-pink-400',
					'.py': 'ph-bold ph-file-py text-yellow-300',
					'.css': 'ph-bold ph-file-css text-purple-400',
					'.scss': 'ph-bold ph-file-css text-purple-400',
					'.html': 'ph-bold ph-file-html text-orange-400',
					'.templ': 'ph-bold ph-file-html text-orange-400',
					'.sql': 'ph-bold ph-database text-emerald-400',
					'.sh': 'ph-bold ph-terminal text-green-300',
					'.bash': 'ph-bold ph-terminal text-green-300',
					'.toml': 'ph-bold ph-file-code text-amber-400',
					'.env': 'ph-bold ph-lock-key text-red-300',
				};
				return map[ext] || 'ph-bold ph-file text-neutral-500';
			}
		</script>
	</div>
}
