package templates

templ OverviewPanel() {
	<div
		class="border-b border-neutral-50/5 bg-neutral-50/2"
		x-data="{
			activeSessions: 0,
			totalAgents: 0,
			costToday: 0,
			uptimeSeconds: 0,
			uptimeStr: '...',
			events: [],
			maxEvents: 10,
			loading: true,
			tick: null,

			async init() {
				await this.fetchStats();
				await this.fetchUptime();
				this.connectSSE();
				this.tick = setInterval(() => {
					this.uptimeSeconds++;
					this.uptimeStr = this.formatUptime(this.uptimeSeconds);
				}, 1000);
				this.loading = false;
			},

			async fetchStats() {
				try {
					const [sessRes, statsRes] = await Promise.all([
						fetch('/api/sessions'),
						fetch('/api/pg/stats')
					]);
					if (sessRes.ok) {
						const sessions = await sessRes.json();
						if (Array.isArray(sessions)) {
							this.activeSessions = sessions.filter(s => s.status === 'active' || s.status === 'waiting').length;
							let agents = 0;
							sessions.forEach(s => {
								if (s.agents) {
									Object.values(s.agents).forEach(a => {
										if (a.status === 'running') agents++;
									});
								}
							});
							this.totalAgents = agents;
						}
					}
					if (statsRes.ok) {
						const stats = await statsRes.json();
						const today = new Date().toISOString().slice(0, 10);
						if (stats.cost_per_day && Array.isArray(stats.cost_per_day)) {
							const todayEntry = stats.cost_per_day.find(d => d.day === today);
							this.costToday = todayEntry ? todayEntry.cost : 0;
						}
					}
				} catch(e) { console.warn('overview stats fetch error:', e); }
			},

			async fetchUptime() {
				try {
					const res = await fetch('/api/health');
					if (res.ok) {
						const data = await res.json();
						this.uptimeSeconds = data.uptime_seconds || 0;
						this.uptimeStr = this.formatUptime(this.uptimeSeconds);
					}
				} catch(e) { console.warn('uptime fetch error:', e); }
			},

			connectSSE() {
				const es = new EventSource('/api/stream');
				const tracked = ['session_start','session_end','agent_spawn','agent_done','message','tool_call','error','pause','resume','waiting','cost_update'];
				tracked.forEach(t => {
					es.addEventListener(t, (e) => {
						try {
							const evt = JSON.parse(e.data);
							this.events.unshift({
								time: new Date(evt.timestamp || Date.now()).toLocaleTimeString('en-US', {hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit'}),
								agent: evt.data?.agent_name || evt.agent_id || evt.data?.from || '—',
								type: t.replace('_', ' '),
								color: this.eventColor(t),
								icon: this.eventIcon(t)
							});
							if (this.events.length > this.maxEvents) this.events.pop();
						} catch(_) {}

						// Refresh counts on state-change events
						if (['session_start','session_end','agent_spawn','agent_done','pause','resume','waiting','cost_update'].includes(t)) {
							this.fetchStats();
						}
					});
				});
				es.onerror = () => { setTimeout(() => this.connectSSE(), 5000); };
			},

			eventColor(t) {
				const map = {
					session_start: 'text-green-400',
					session_end: 'text-blue-400',
					agent_spawn: 'text-cyan-400',
					agent_done: 'text-cyan-300',
					message: 'text-neutral-300',
					tool_call: 'text-amber-400',
					error: 'text-red-400',
					pause: 'text-amber-400',
					resume: 'text-green-400',
					waiting: 'text-yellow-400',
					cost_update: 'text-neutral-500'
				};
				return map[t] || 'text-neutral-400';
			},

			eventIcon(t) {
				const map = {
					session_start: 'ph-play-circle',
					session_end: 'ph-stop-circle',
					agent_spawn: 'ph-robot',
					agent_done: 'ph-check-circle',
					message: 'ph-chat-dots',
					tool_call: 'ph-wrench',
					error: 'ph-warning-octagon',
					pause: 'ph-pause-circle',
					resume: 'ph-play-circle',
					waiting: 'ph-hourglass',
					cost_update: 'ph-coins'
				};
				return map[t] || 'ph-info';
			},

			formatUptime(s) {
				if (s < 60) return s + 's';
				if (s < 3600) return Math.floor(s/60) + 'm ' + (s%60) + 's';
				const h = Math.floor(s/3600);
				const m = Math.floor((s%3600)/60);
				if (h < 24) return h + 'h ' + m + 'm';
				const d = Math.floor(h/24);
				return d + 'd ' + (h%24) + 'h';
			}
		}"
	>
		<div class="flex gap-0">
			<!-- Left: Status Cards -->
			<div class="flex-1 p-4">
				<div class="grid grid-cols-4 gap-3">
					<!-- Active Sessions -->
					<div class="glass rounded-lg p-3 flex flex-col gap-1">
						<div class="flex items-center justify-between">
							<span class="text-xs text-neutral-500 uppercase tracking-wider">Active Sessions</span>
							<template x-if="activeSessions > 0">
								<span class="w-2 h-2 rounded-full bg-green-400 pulse"></span>
							</template>
							<template x-if="activeSessions === 0">
								<span class="w-2 h-2 rounded-full bg-neutral-600"></span>
							</template>
						</div>
						<div class="text-2xl font-bold neon-green" x-text="activeSessions">0</div>
					</div>

					<!-- Total Agents Running -->
					<div class="glass rounded-lg p-3 flex flex-col gap-1">
						<div class="flex items-center justify-between">
							<span class="text-xs text-neutral-500 uppercase tracking-wider">Agents Running</span>
							<i class="ph-bold ph-robot text-neutral-600"></i>
						</div>
						<div class="text-2xl font-bold neon-pink" x-text="totalAgents">0</div>
					</div>

					<!-- Cost Today -->
					<div class="glass rounded-lg p-3 flex flex-col gap-1">
						<div class="flex items-center justify-between">
							<span class="text-xs text-neutral-500 uppercase tracking-wider">Cost Today</span>
							<i class="ph-bold ph-coins text-neutral-600"></i>
						</div>
						<div class="text-2xl font-bold neon-yellow" x-text="'$' + costToday.toFixed(3)">$0.000</div>
					</div>

					<!-- Uptime -->
					<div class="glass rounded-lg p-3 flex flex-col gap-1">
						<div class="flex items-center justify-between">
							<span class="text-xs text-neutral-500 uppercase tracking-wider">Uptime</span>
							<i class="ph-bold ph-timer text-neutral-600"></i>
						</div>
						<div class="text-2xl font-bold text-neutral-200" x-text="uptimeStr">...</div>
					</div>
				</div>
			</div>

			<!-- Right: Live Activity Feed -->
			<div class="w-[300px] border-l border-neutral-50/5 p-3 flex flex-col">
				<div class="flex items-center justify-between mb-2">
					<h3 class="text-xs font-bold text-neutral-400 uppercase tracking-wider flex items-center gap-1.5">
						<span class="w-1.5 h-1.5 rounded-full bg-green-400 pulse"></span>
						Live Activity
					</h3>
					<span class="text-xs text-neutral-600" x-text="events.length + ' events'"></span>
				</div>
				<div class="flex-1 overflow-y-auto scrollbar-thin space-y-0.5 max-h-[120px]">
					<template x-if="events.length === 0">
						<div class="text-xs text-neutral-600 text-center py-4">Waiting for events...</div>
					</template>
					<template x-for="(evt, i) in events" :key="i">
						<div class="flex items-start gap-2 py-1 px-1.5 rounded hover:bg-neutral-50/3 transition-colors">
							<span class="text-xs text-neutral-600 font-mono whitespace-nowrap" x-text="evt.time"></span>
							<i class="ph-bold text-xs mt-0.5" :class="evt.icon + ' ' + evt.color"></i>
							<div class="flex-1 min-w-0">
								<span class="text-xs font-medium truncate block" :class="evt.color" x-text="evt.type"></span>
								<span class="text-xs text-neutral-500 truncate block" x-text="evt.agent"></span>
							</div>
						</div>
					</template>
				</div>
			</div>
		</div>
	</div>
}
