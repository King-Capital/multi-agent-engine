package templates

import "github.com/goinfinite/ui/src/import"

templ Layout(title string) {
	<!DOCTYPE html>
	<html lang="en" class="h-full">
		<head>
			<meta charset="UTF-8"/>
			<title>{ title } | Agent Dashboard</title>
			@uiImport.HeadTagsMinimalCss()
			@uiImport.HeadTagsFullJs()
			<script src="https://cdn.jsdelivr.net/npm/idiomorph@0.3.0/dist/idiomorph-ext.min.js"></script>
			<script src="https://cdn.jsdelivr.net/npm/marked@15.0.12/marked.min.js"></script>
			<style>
				body {
					font-family: "Lato", "Helvetica Neue", Arial, sans-serif;
					background: #0a0e17;
					color: #e2e8f0;
				}
				.agent-line { border-left: 2px solid #334155; margin-left: 12px; padding-left: 12px; }
				.pulse { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
				@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .5; } }
				.glass { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); backdrop-filter: blur(8px); }
				.neon-green { color: #36f9f6; }
				.neon-pink { color: #ff6b9d; }
				.neon-yellow { color: #ffd93d; }
				.scrollbar-thin::-webkit-scrollbar { width: 6px; }
				.scrollbar-thin::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 3px; }
				.scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
				.msg-md h1,.msg-md h2,.msg-md h3 { font-weight:700; margin:0.5em 0 0.25em; }
				.msg-md h1 { font-size:1.1em; color:#36f9f6; }
				.msg-md h2 { font-size:1em; color:#ffd93d; }
				.msg-md h3 { font-size:0.9em; color:#94a3b8; }
				.msg-md p { margin:0.25em 0; }
				.msg-md ul,.msg-md ol { margin:0.25em 0; padding-left:1.25em; }
				.msg-md li { margin:0.1em 0; }
				.msg-md code { background:rgba(255,255,255,0.08); padding:0.1em 0.3em; border-radius:3px; font-size:0.85em; }
				.msg-md pre { background:rgba(0,0,0,0.3); padding:0.5em; border-radius:4px; overflow-x:auto; margin:0.5em 0; }
				.msg-md pre code { background:none; padding:0; }
				.msg-md strong { color:#e2e8f0; }
				.msg-md table { border-collapse:collapse; width:100%; margin:0.5em 0; font-size:0.85em; }
				.msg-md th,.msg-md td { border:1px solid rgba(255,255,255,0.1); padding:0.25em 0.5em; text-align:left; }
				.msg-md th { background:rgba(255,255,255,0.05); font-weight:600; }
			</style>
		</head>
		<body class="h-full bg-[#0a0e17] text-neutral-200">
			{ children... }
			<script>
				function renderMd() {
					document.querySelectorAll('.msg-md[data-md]').forEach(el => {
						if (el.dataset.rendered) return;
						const raw = el.dataset.md;
						if (raw && typeof marked !== 'undefined') {
							el.innerHTML = marked.parse(raw);
							el.dataset.rendered = '1';
						} else if (raw) {
							el.textContent = raw;
						}
					});
				}
				renderMd();
				document.body.addEventListener('htmx:afterSwap', renderMd);
				document.body.addEventListener('htmx:afterSettle', renderMd);
			</script>
		</body>
	</html>
}
