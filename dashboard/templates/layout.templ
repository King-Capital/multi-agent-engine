package templates

import "github.com/goinfinite/ui/src/import"

templ Layout(title string) {
	<!DOCTYPE html>
	<html lang="en" class="h-full">
		<head>
			<meta charset="UTF-8"/>
			<title>{ title } | Agent Dashboard</title>
			@uiImport.HeadTagsMinimalCss()
			@uiImport.HeadTagsFullJs()
			<script src="https://cdn.jsdelivr.net/npm/idiomorph@0.3.0/dist/idiomorph-ext.min.js"></script>
			<script src="https://cdn.jsdelivr.net/npm/marked@15.0.12/marked.min.js"></script>
			<style>
				body {
					font-family: "Lato", "Helvetica Neue", Arial, sans-serif;
					background: #0a0e17;
					color: #e2e8f0;
				}
				.agent-line { border-left: 2px solid #334155; margin-left: 12px; padding-left: 12px; }
				.pulse { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
				@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .5; } }
				.glass { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); backdrop-filter: blur(8px); }
				.neon-green { color: #36f9f6; }
				.neon-pink { color: #ff6b9d; }
				.neon-yellow { color: #ffd93d; }
				.scrollbar-thin::-webkit-scrollbar { width: 6px; }
				.scrollbar-thin::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.2); border-radius: 3px; }
				.scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
				.msg-md h1,.msg-md h2,.msg-md h3 { font-weight:700; margin:0.5em 0 0.25em; }
				.msg-md h1 { font-size:1.1em; color:#36f9f6; }
				.msg-md h2 { font-size:1em; color:#ffd93d; }
				.msg-md h3 { font-size:0.9em; color:#94a3b8; }
				.msg-md p { margin:0.25em 0; }
				.msg-md ul,.msg-md ol { margin:0.25em 0; padding-left:1.25em; }
				.msg-md li { margin:0.1em 0; }
				.msg-md code { background:rgba(255,255,255,0.08); padding:0.1em 0.3em; border-radius:3px; font-size:0.85em; }
				.msg-md pre { background:rgba(0,0,0,0.3); padding:0.5em; border-radius:4px; overflow-x:auto; margin:0.5em 0; }
				.msg-md pre code { background:none; padding:0; }
				.msg-md strong { color:#e2e8f0; }
				.msg-md table { border-collapse:collapse; width:100%; margin:0.5em 0; font-size:0.85em; }
				.msg-md th,.msg-md td { border:1px solid rgba(255,255,255,0.1); padding:0.25em 0.5em; text-align:left; }
				.msg-md th { background:rgba(255,255,255,0.05); font-weight:600; }
			</style>
		</head>
		<body class="h-full bg-[#0a0e17] text-neutral-200">
			{ children... }
			<script>
				function renderMd(root) {
					(root || document).querySelectorAll('.msg-md[data-md]').forEach(el => {
						if (el.dataset.rendered) return;
						const raw = el.dataset.md;
						if (raw && typeof marked !== 'undefined') {
							el.innerHTML = marked.parse(raw);
							el.dataset.rendered = '1';
						} else if (raw) {
							el.textContent = raw;
						}
					});
				}
				function reinitAlpine(root) {
					if (typeof Alpine === 'undefined') return;
					(root || document).querySelectorAll('[x-data]').forEach(el => {
						if (!el._x_dataStack) Alpine.initTree(el);
					});
				}

				// SSE client for session pages
				var __sseBuffer = [];
				var __ssePaused = false;
				var __sseSource = null;

				function initSessionSSE(sessionId) {
					const conv = document.getElementById('conversation');
					if (!conv) return;
					const es = new EventSource('/htmx/session/' + sessionId + '/stream');
					__sseSource = es;

					const indicator = document.getElementById('sse-status');

					function appendHTML(html) {
						if (__ssePaused) { __sseBuffer.push(html); return; }
						conv.insertAdjacentHTML('beforeend', html);
						const added = conv.lastElementChild;
						if (added) { renderMd(added); reinitAlpine(added); }
						const nearBottom = conv.scrollHeight - conv.scrollTop - conv.clientHeight < 150;
						if (nearBottom) conv.scrollTop = conv.scrollHeight;
					}

					// Conversation events — server sends rendered HTML
					['message', 'tool_call', 'domain_block', 'self_heal', 'agent_error'].forEach(t => {
						es.addEventListener(t, e => appendHTML(e.data));
					});

					// Panel refresh events — server sends JSON, we trigger HTMX fetches
					['agent_spawn', 'agent_done'].forEach(t => {
						es.addEventListener(t, () => {
							htmx.ajax('GET', '/htmx/session/' + sessionId + '/agents', {target:'#agent-tree', swap:'innerHTML'});
							htmx.ajax('GET', '/htmx/session/' + sessionId + '/costs', {target:'#costs', swap:'innerHTML'});
						});
					});
					es.addEventListener('cost_update', () => {
						htmx.ajax('GET', '/htmx/session/' + sessionId + '/costs', {target:'#costs', swap:'innerHTML'});
					});
					es.addEventListener('tilldone', e => {
						htmx.ajax('GET', '/htmx/session/' + sessionId + '/tilldone', {target:'#tilldone', swap:'innerHTML'});
						try {
							const evt = JSON.parse(e.data);
							const td = evt.data && evt.data.tilldone;
							const badge = document.getElementById('tilldone-badge');
							if (td && badge) badge.textContent = 'TillDone: [' + td.completed + '/' + td.total + ']';
						} catch(_) {}
					});

					// Session status changes
					es.addEventListener('session_end', () => updateStatusBadge('completed', 'bg-blue-500/20 text-blue-400'));
					es.addEventListener('pause', () => updateStatusBadge('paused', 'bg-amber-500/20 text-amber-400'));
					es.addEventListener('resume', () => updateStatusBadge('active', 'bg-green-500/20 text-green-400'));
					es.addEventListener('waiting', () => updateStatusBadge('waiting', 'bg-yellow-500/20 text-yellow-400'));

					es.onopen = () => { if (indicator) { indicator.textContent = '●'; indicator.className = 'text-xs text-green-500'; indicator.title = 'SSE connected'; } };
					es.onerror = () => { if (indicator) { indicator.textContent = '●'; indicator.className = 'text-xs text-red-500'; indicator.title = 'SSE reconnecting...'; } };
				}

				function updateStatusBadge(text, cls) {
					const b = document.getElementById('status-badge');
					if (b) { b.textContent = text; b.className = 'px-1.5 py-0.5 rounded text-xs ' + cls; }
				}

				function toggleSSEPause(paused) {
					__ssePaused = paused;
					if (!paused && __sseBuffer.length > 0) {
						const conv = document.getElementById('conversation');
						__sseBuffer.forEach(html => conv.insertAdjacentHTML('beforeend', html));
						renderMd(conv);
						reinitAlpine(conv);
						conv.scrollTop = conv.scrollHeight;
						__sseBuffer = [];
					}
				}

				function initDashboardSSE() {
					const es = new EventSource('/api/stream');
					let pending = null;
					function refresh() {
						if (window.__ctxMenuOpen) return;
						if (pending) return;
						pending = setTimeout(() => {
							htmx.ajax('GET', '/htmx/sessions', {target:'#session-list', swap:'innerHTML'});
							pending = null;
						}, 500);
					}
					['session_start','session_end','agent_spawn','agent_done','cost_update','pause','resume','waiting'].forEach(t => {
						es.addEventListener(t, refresh);
					});
					es.addEventListener('error', e => { if (e instanceof MessageEvent) refresh(); });
					// Initial refresh on connect to catch sessions that started before page load
					es.onopen = () => refresh();
				}

				renderMd();
				document.body.addEventListener('htmx:afterSwap', (e) => { renderMd(); reinitAlpine(e.detail.elt); });
				document.body.addEventListener('htmx:afterSettle', () => { renderMd(); });
			</script>
		</body>
	</html>
}
